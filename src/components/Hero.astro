---
interface Cta {
  label: string;
  href: string;
  icon?: string;
}

interface Badge {
  text: string;
  dotAnimated?: boolean;
}

interface Props {
  badge?: Badge;
  title: string;
  subtitle: string;
  primaryCta: Cta;
  secondaryCta?: Cta;
  reassurance?: string;
}

const { badge, title, subtitle, primaryCta, secondaryCta, reassurance } = Astro.props;
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        {badge && (
          <div class="hero-badge">
            {badge.dotAnimated && <span class="hero-badge-dot" aria-hidden="true"></span>}
            {badge.text}
          </div>
        )}
        <h1 set:html={title} />
        <p>{subtitle}</p>
        <div class="hero-ctas">
          <a href={primaryCta.href} class="btn-primary">
            {primaryCta.label}
            {primaryCta.icon && <span aria-hidden="true" set:html={primaryCta.icon} />}
          </a>
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-secondary">
              {secondaryCta.icon && <span aria-hidden="true" set:html={secondaryCta.icon} />}
              {secondaryCta.label}
            </a>
          )}
        </div>
        {reassurance && <p class="hero-reassurance">{reassurance}</p>}
        <slot />
      </div>
      <div class="hero-visual" aria-hidden="true">
        <slot name="visual" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--navy);
    color: white;
    padding: 72px 0 56px;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -300px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -200px; left: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(70,120,220,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--brand-soft);
    color: var(--brand-light);
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    border: 1px solid rgba(70,120,220,0.3);
    margin-bottom: 22px;
  }
  .hero-badge-dot {
    width: 7px; height: 7px;
    background: var(--brand-light);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(107,147,232,0.5); }
    50% { opacity: 0.6; transform: scale(1.2); box-shadow: 0 0 0 6px rgba(107,147,232,0); }
  }
  h1 {
    font-size: clamp(38px, 5vw, 58px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 20px;
    color: white;
  }
  :global(.hero h1 em) {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: var(--brand-light);
    letter-spacing: -0.01em;
  }
  .hero-content > p {
    font-size: 17px;
    line-height: 1.6;
    color: #cbd5e1;
    margin-bottom: 30px;
    max-width: 520px;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--brand);
    color: white;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    box-shadow: 0 1px 3px rgba(70,120,220,0.3);
  }
  .btn-primary:hover { background: var(--brand-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(70,120,220,0.4); }
  .btn-secondary {
    background: transparent;
    color: white;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255,255,255,0.25);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.4); }
  .hero-reassurance {
    font-size: 13px;
    color: #94a3b8;
    margin-bottom: 32px;
  }
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 440px;
  }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { min-height: 360px; order: -1; }
  }
  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
  }
</style>
