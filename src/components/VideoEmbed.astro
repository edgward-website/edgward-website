---
interface Props {
  src: string;
  poster?: string;
  title: string;
}

const { src, poster, title } = Astro.props;
const uid = Math.random().toString(36).slice(2);
---

<div class="video-wrap" data-uid={uid}>
  {poster ? (
    <button class="video-poster" aria-label={`Lire la vidéo : ${title}`}>
      <img src={poster} alt="" class="video-poster-img">
      <div class="video-play-btn" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </div>
    </button>
  ) : (
    <button class="video-poster video-poster--no-img" aria-label={`Lire la vidéo : ${title}`}>
      <div class="video-play-btn" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </div>
      <span class="video-title">{title}</span>
    </button>
  )}
  <div class="video-frame" hidden>
    <iframe
      src={src}
      title={title}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
</div>

<script>
  document.querySelectorAll('.video-wrap').forEach(wrap => {
    const btn = wrap.querySelector('.video-poster') as HTMLButtonElement | null;
    const frame = wrap.querySelector('.video-frame') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      btn.hidden = true;
      if (frame) frame.hidden = false;
    });
  });
</script>

<style>
  .video-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--navy);
    position: relative;
    aspect-ratio: 16/9;
  }
  .video-poster {
    width: 100%; height: 100%;
    border: none;
    cursor: pointer;
    padding: 0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
  }
  .video-poster--no-img { background: var(--navy-light); }
  .video-poster-img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }
  .video-play-btn {
    width: 64px; height: 64px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    position: relative;
    z-index: 1;
    transition: all 0.2s ease;
    border: 2px solid rgba(255,255,255,0.3);
  }
  .video-poster:hover .video-play-btn { background: var(--brand); border-color: var(--brand); transform: scale(1.1); }
  .video-title { position: relative; z-index: 1; color: white; font-size: 14px; font-weight: 600; margin-top: 16px; }
  .video-frame { width: 100%; height: 100%; position: absolute; inset: 0; }
  iframe { width: 100%; height: 100%; border: none; }
</style>
