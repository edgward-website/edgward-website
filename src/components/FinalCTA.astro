---
interface Props {
  title: string;
  description: string;
  appStoreUrl?: string;
  playStoreUrl?: string;
  image?: string;
}

const {
  title,
  description,
  appStoreUrl = 'https://apps.apple.com/ch/app/edgward/id6503622410',
  playStoreUrl = 'https://play.google.com/store/apps/details?id=ch.edgward.app.clients',
  image = '/assets/ed-pouce.png',
} = Astro.props;
---

<section class="final-cta" id="telecharger">
  <div class="container">
    <div class="final-grid">
      <img src={image} alt="" class="final-ed" width="180" height="180" aria-hidden="true" loading="lazy">
      <div class="final-left">
        <h2 set:html={title} />
        <p>{description}</p>
        <div class="stores">
          <a href={appStoreUrl} class="store-btn" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div>
              <span class="store-sub">Télécharger sur</span>
              <span class="store-main">App Store</span>
            </div>
          </a>
          <a href={playStoreUrl} class="store-btn" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.19l2.807 1.626a1 1 0 010 1.73l-2.808 1.626-2.496-2.491 2.497-2.491zM5.864 2.658L16.802 8.99l-2.302 2.302-8.636-8.634z"/></svg>
            <div>
              <span class="store-sub">Disponible sur</span>
              <span class="store-main">Google Play</span>
            </div>
          </a>
        </div>
      </div>
      <div class="email-card">
        <h4>Pas encore prêt ?</h4>
        <p>Recevez notre guide « Sécuriser son domicile » par email.</p>
        <form class="email-form" id="final-email-form" novalidate>
          <input type="email" name="email" placeholder="votre@email.ch" aria-label="Votre adresse email" autocomplete="email" required>
          <button type="submit">Recevoir</button>
        </form>
        <p class="email-privacy">En vous inscrivant, vous acceptez notre <a href="/confidentialite">politique de confidentialité</a>.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('final-email-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = form.querySelector('input[type="email"]') as HTMLInputElement;
    if (!input.validity.valid) { input.focus(); return; }
    const btn = form.querySelector('button') as HTMLButtonElement;
    btn.textContent = 'Envoyé ✓';
    btn.disabled = true;
    input.disabled = true;
  });
</script>

<style>
  .final-cta {
    background: var(--navy);
    color: white;
    padding: 88px 0;
    position: relative;
    overflow: hidden;
  }
  .final-cta::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 900px; height: 900px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 55%);
    pointer-events: none;
  }
  .final-grid {
    display: grid;
    grid-template-columns: auto 1.2fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .final-ed {
    width: 180px;
    filter: drop-shadow(0 12px 40px rgba(70,120,220,0.4));
  }
  .final-left h2 {
    font-size: clamp(28px, 3.2vw, 38px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: white;
    margin-bottom: 14px;
  }
  :global(.final-left h2 em) {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: var(--brand-light);
  }
  .final-left p { font-size: 15px; color: #cbd5e1; margin-bottom: 24px; line-height: 1.6; }
  .stores { display: flex; gap: 10px; flex-wrap: wrap; }
  .store-btn {
    background: #000;
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    padding: 10px 18px;
    border-radius: 10px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.2s ease;
  }
  .store-btn:hover { background: #1a1a1a; border-color: rgba(255,255,255,0.3); }
  .store-sub { font-size: 10px; color: #94a3b8; display: block; line-height: 1.2; }
  .store-main { font-size: 13px; font-weight: 600; display: block; line-height: 1.2; }
  .email-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-lg);
    padding: 24px;
  }
  .email-card h4 { font-size: 16px; font-weight: 700; color: white; margin-bottom: 6px; letter-spacing: -0.01em; }
  .email-card > p { font-size: 12px; color: #cbd5e1; margin-bottom: 14px; line-height: 1.5; }
  .email-form { display: flex; gap: 8px; margin-bottom: 10px; }
  .email-form input {
    flex: 1;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 13px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease;
    min-width: 0;
  }
  .email-form input::placeholder { color: #94a3b8; }
  .email-form input:focus { border-color: var(--brand); }
  .email-form button {
    background: var(--brand);
    color: white;
    border: none;
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: all 0.2s ease;
  }
  .email-form button:hover { background: var(--brand-dark); }
  .email-form button:disabled { opacity: 0.7; cursor: default; }
  .email-privacy { font-size: 11px; color: #64748b; }
  .email-privacy a { color: #94a3b8; }
  .email-privacy a:hover { color: white; }

  @media (max-width: 1024px) {
    .final-grid { grid-template-columns: 1fr; gap: 32px; text-align: center; }
    .final-ed { margin: 0 auto; width: 140px; }
    .stores { justify-content: center; }
  }
</style>
