---
interface Props {
  mediaName: string;
  date: string;
  excerpt: string;
  url: string;
  logo?: string;
  type?: 'article' | 'radio' | 'video';
}

const { mediaName, date, excerpt, url, logo, type = 'article' } = Astro.props;

const cta = {
  article: 'Lire l\'article',
  radio: 'Écouter le podcast',
  video: 'Voir l\'émission',
}[type];
---

<article class="media-card">
  <div class="media-header">
    {logo ? (
      <img src={logo} alt={`Logo ${mediaName}`} class="media-logo" width="80" height="32" loading="lazy">
    ) : (
      <span class="media-name-badge">{mediaName}</span>
    )}
    <time class="media-date">{date}</time>
  </div>
  <p class="media-excerpt">{excerpt}</p>
  <a href={url} class="media-link" target="_blank" rel="noopener noreferrer">
    {cta}
    {type === 'article' && (
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
    )}
    {type === 'radio' && (
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a1 1 0 01-1-1v-3a1 1 0 011-1h3zM3 19a2 2 0 002 2h1a1 1 0 001-1v-3a1 1 0 00-1-1H3z"/></svg>
    )}
    {type === 'video' && (
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"/></svg>
    )}
  </a>
</article>

<style>
  .media-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: all 0.2s ease;
  }
  .media-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
  .media-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .media-logo { max-height: 28px; width: auto; object-fit: contain; }
  .media-name-badge {
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.01em;
  }
  .media-date {
    font-size: 12px;
    color: var(--text-light);
  }
  .media-excerpt {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }
  .media-link {
    font-size: 13px;
    color: var(--brand);
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.15s ease;
    align-self: flex-start;
  }
  .media-link:hover { color: var(--brand-dark); }
</style>
