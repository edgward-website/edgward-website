---
interface Props {
  /** Optional small uppercase label above the title. */
  eyebrow?: string;
  /** Main heading. Supports inline <em> for the serif accent. */
  title: string;
  /** Optional intro paragraph below the title. */
  subtitle?: string;
  /** Max width of the centered content (default 640px). */
  maxWidth?: string;
}

const { eyebrow, title, subtitle, maxWidth = '640px' } = Astro.props;
---

<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner" style={`max-width:${maxWidth}`}>
      {eyebrow && <span class="page-hero-eyebrow">{eyebrow}</span>}
      <h1 set:html={title} />
      {subtitle && <p class="page-hero-sub">{subtitle}</p>}
    </div>
  </div>
</section>

<style>
  .page-hero {
    background: var(--navy);
    color: white;
    padding: 72px 0 56px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative;
    z-index: 1;
    margin: 0 auto;
  }
  .page-hero-eyebrow {
    display: inline-block;
    font-size: 12px;
    color: var(--brand-light);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }
  .page-hero h1 {
    font-size: clamp(34px, 4.5vw, 52px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
    color: white;
  }
  :global(.page-hero h1 em) {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: var(--brand-light);
  }
  .page-hero-sub {
    font-size: 17px;
    color: #cbd5e1;
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto;
  }
</style>
