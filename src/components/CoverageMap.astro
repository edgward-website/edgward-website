<style>
  :root {
    --vert: #10b981;
    --orange: #f59e0b;
    --rouge: #ef4444;
    --gris: #e5e7eb;
    --gris-fonce: #9ca3af;
  }

  .coverage-map-wrap {
    width: 100%;
  }

  .cm-card {
    background: #ffffff;
    border-radius: 24px;
    box-shadow: 0 1px 2px rgba(15,23,42,.04), 0 8px 32px rgba(15,23,42,.06);
    overflow: hidden;
    border: 1px solid #e2e8f0;
  }

  .map-area {
    padding: 24px;
    position: relative;
  }

  .map-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .canton {
    cursor: pointer;
    transition: filter 0.2s ease, opacity 0.2s ease;
    stroke: #ffffff;
    stroke-width: 1.4;
    stroke-linejoin: round;
  }
  .canton:hover {
    filter: brightness(1.08) drop-shadow(0 3px 8px rgba(0,0,0,.15));
  }
  .canton.dimmed { opacity: 0.3; }

  .canton-complet  { fill: var(--vert); }
  .canton-partiel  { fill: var(--orange); }
  .canton-non      { fill: var(--rouge); }
  .canton-contexte { fill: var(--gris); cursor: default; }
  .canton-contexte:hover { filter: none; }

  .lake {
    fill: #cfe8f5;
    stroke: #ffffff;
    stroke-width: 0.6;
    pointer-events: none;
  }

  .label {
    pointer-events: none;
    text-anchor: middle;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    paint-order: stroke fill;
  }
  .label-color {
    fill: #ffffff;
    stroke: rgba(0,0,0,0.18);
    stroke-width: 0.4;
  }
  .label-gris {
    fill: #6b7280;
    stroke: none;
  }
  .label-code { font-size: 13px; letter-spacing: 0.5px; }
  .label-name { font-size: 10px; font-weight: 600; }

  .cm-legend {
    padding: 20px 28px 28px;
    border-top: 1px solid #e2e8f0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: #fafbfc;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    transition: all 0.2s;
    cursor: pointer;
  }
  .legend-item:hover,
  .legend-item:focus {
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(15,23,42,0.06);
    outline: none;
  }
  .legend-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(255,255,255,0.8);
  }
  .legend-text { display: flex; flex-direction: column; line-height: 1.3; }
  .legend-title { font-size: 13px; font-weight: 600; color: #0f172a; font-family: 'Manrope', sans-serif; }
  .legend-meta { font-size: 11px; color: #64748b; margin-top: 1px; font-family: 'Manrope', sans-serif; }

  .tooltip {
    position: absolute;
    pointer-events: none;
    background: rgba(15, 23, 42, 0.95);
    color: white;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px;
    font-family: 'Manrope', sans-serif;
    line-height: 1.4;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.15s, transform 0.15s;
    z-index: 10;
    white-space: nowrap;
  }
  .tooltip.show { opacity: 1; transform: translateY(0); }
  .tooltip-title { font-weight: 700; margin-bottom: 3px; }
  .tooltip-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: rgba(255,255,255,0.85);
  }
  .tooltip-dot { width: 8px; height: 8px; border-radius: 50%; }

  .cm-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: #e2e8f0;
    border-top: 1px solid #e2e8f0;
  }
  .stat {
    background: #ffffff;
    padding: 22px;
    text-align: center;
  }
  .stat-value {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    font-family: 'Manrope', sans-serif;
    color: #0f172a;
  }
  .stat-label {
    font-size: 11px;
    color: #64748b;
    margin-top: 2px;
    font-weight: 500;
    letter-spacing: 0.5px;
    font-family: 'Manrope', sans-serif;
  }

  @media (max-width: 768px) {
    .map-area { padding: 14px; }
    .cm-legend { padding: 14px 18px 18px; }
    .cm-stats { grid-template-columns: 1fr; }
    .label { display: none; }
    .label-code { font-size: 11px; }
    .label-name { font-size: 9px; }
  }
</style>

<script>
  (function() {
    const cmTooltip = document.getElementById('cmTooltip');
    const cmTitle = document.getElementById('cmTitle');
    const cmStatus = document.getElementById('cmStatus');
    const cmDot = document.getElementById('cmDot');
    const mapArea = document.getElementById('mapArea');
    const cantons = document.querySelectorAll('.canton');
    const legendItems = document.querySelectorAll('.legend-item');

    const statusInfo = {
      complet:  { label: 'Complètement couvert', color: 'var(--vert)' },
      partiel:  { label: 'Partiellement couvert', color: 'var(--orange)' },
      non:      { label: 'Non couvert',           color: 'var(--rouge)' },
      contexte: { label: 'Hors zone romande',     color: 'var(--gris-fonce)' }
    };

    cantons.forEach(c => {
      c.addEventListener('mouseenter', () => {
        cmTitle.textContent = c.dataset.name;
        const info = statusInfo[c.dataset.status];
        cmStatus.textContent = info.label;
        cmDot.style.background = info.color;
        cmTooltip.classList.add('show');
      });
      c.addEventListener('mousemove', e => {
        const rect = mapArea.getBoundingClientRect();
        cmTooltip.style.left = (e.clientX - rect.left + 14) + 'px';
        cmTooltip.style.top  = (e.clientY - rect.top + 14) + 'px';
      });
      c.addEventListener('mouseleave', () => cmTooltip.classList.remove('show'));
    });

    legendItems.forEach(item => {
      const filter = item.dataset.filter;
      const dimOthers = () => {
        cantons.forEach(c => {
          if (c.dataset.status === 'contexte') return;
          if (c.dataset.status !== filter) c.classList.add('dimmed');
        });
      };
      const undim = () => {
        cantons.forEach(c => c.classList.remove('dimmed'));
      };
      item.addEventListener('mouseenter', dimOthers);
      item.addEventListener('mouseleave', undim);
      item.addEventListener('focus', dimOthers);
      item.addEventListener('blur', undim);
    });
  })();
</script>
