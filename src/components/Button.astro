---
interface Props {
  variant?: 'primary' | 'secondary' | 'dark' | 'ghost';
  href?: string;
  external?: boolean;
  class?: string;
}

const { variant = 'primary', href, external = false, class: className = '' } = Astro.props;
const tag = href ? 'a' : 'button';
const externalAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{href ? (
  <a href={href} class={`btn btn-${variant} ${className}`} {...externalAttrs}>
    <slot />
    <slot name="icon" />
  </a>
) : (
  <button class={`btn btn-${variant} ${className}`} type="button">
    <slot />
    <slot name="icon" />
  </button>
)}

