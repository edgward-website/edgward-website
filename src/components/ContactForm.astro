---
interface Props {
  action?: string;
  defaultSubject?: string;
}

const {
  action = 'mailto:info@edgward.ch',
  defaultSubject,
} = Astro.props;

const subjects = ['Particulier', 'Entreprise', 'Commune', 'Centrale d\'alarme', 'Autre'];
---

<div class="contact-form-wrap">
  <form class="contact-form" novalidate id="contact-form" data-context={defaultSubject ?? ''}>
    <div class="form-row">
      <div class="form-group">
        <label for="cf-nom">Nom complet</label>
        <input type="text" id="cf-nom" name="nom" placeholder="Jean Dupont" autocomplete="name" required>
      </div>
      <div class="form-group">
        <label for="cf-email">Email</label>
        <input type="email" id="cf-email" name="email" placeholder="jean@example.ch" autocomplete="email" required>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="cf-telephone">Téléphone</label>
        <input type="tel" id="cf-telephone" name="telephone" placeholder="+41 79 123 45 67" autocomplete="tel" inputmode="tel" required>
      </div>
      <div class="form-group">
        <label for="cf-sujet">Sujet</label>
        <select id="cf-sujet" name="sujet" required>
          <option value="" disabled selected={!defaultSubject}>Choisissez un sujet</option>
          {subjects.map(s => (
            <option value={s} selected={defaultSubject === s}>{s}</option>
          ))}
        </select>
      </div>
    </div>
    <div class="form-group">
      <label for="cf-message">Message</label>
      <textarea id="cf-message" name="message" rows="5" placeholder="Décrivez votre besoin..." required></textarea>
    </div>
    <input type="text" name="email_address_check" value="" tabindex="-1" autocomplete="off" aria-hidden="true" class="cf-hp">
    <button type="submit" class="btn-submit">
      Envoyer le message
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </button>
    <p class="form-privacy">En envoyant ce message, vous acceptez notre <a href="/confidentialite">politique de confidentialité</a>.</p>
  </form>
  <div class="contact-success" id="contact-success" hidden>
    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 12.5l2.5 2.5L16 9.5"/></svg>
    <h3>Message envoyé&nbsp;!</h3>
    <p>Merci, votre demande a bien été transmise. Notre équipe vous répond dans les meilleurs délais.</p>
  </div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successBox = document.getElementById('contact-success');
  const BREVO_CONTACT_ACTION = 'https://87714af1.sibforms.com/serve/MUIFACeUMEzMccQ08jYHlzrdNpWoRrnKzHQmfX53dXh3078PAXXC3bDI0rzN0FcL7yQIGvijOqpaNaHdOjgoOWJ0h_xT7KN4dQy7e-dZ-47FALbyi6DffXwBux4VqYLN-Z7VKjeO_D3znDM-oK3wufPUoBSGyWitQx2h1rhHU_u3hjMH8qe9N4GbLlzOUn60ndvujAgptth1dR8i';
  const SUBJECT_MAP: Record<string, string> = {
    'Particulier': '1',
    'Entreprise': '2',
    'Commune': '3',
    "Centrale d'alarme": '4',
    'Autre': '5',
  };
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const honeypot = (form.elements.namedItem('email_address_check') as HTMLInputElement)?.value;
    if (honeypot) return;
    const data = new FormData(form);
    const nom = String(data.get('nom') || '').trim();
    const email = String(data.get('email') || '').trim();
    const telephone = String(data.get('telephone') || '').trim();
    const sujet = String(data.get('sujet') || '');
    const message = String(data.get('message') || '').trim();
    if (!form.checkValidity() || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
      form.reportValidity();
      return;
    }
    const btn = form.querySelector('.btn-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Envoi…';
    const ctx = (form.getAttribute('data-context') || '').trim();
    let composed = message;
    if (telephone) composed = 'Tél : ' + telephone + ' - ' + composed;
    if (ctx && !SUBJECT_MAP[ctx]) composed = composed + ' [Contexte : ' + ctx + ']';
    composed = composed.slice(0, 255);
    const params = new URLSearchParams();
    params.append('NOM', nom);
    params.append('EMAIL', email);
    params.append('SUJET', SUBJECT_MAP[sujet] || '5');
    params.append('MESSAGE', composed);
    params.append('email_address_check', '');
    params.append('locale', 'en');
    fetch(BREVO_CONTACT_ACTION, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: params,
      keepalive: true,
    }).catch(() => {});
    if (successBox) {
      form.hidden = true;
      successBox.hidden = false;
      successBox.setAttribute('tabindex', '-1');
      (successBox as HTMLElement).focus();
      (successBox as HTMLElement).scrollIntoView({ block: 'center', behavior: 'smooth' });
    }
  });
</script>

<style>
  .contact-form-wrap {
    max-width: 640px;
    margin: 0 auto;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  label {
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
  }
  input, select, textarea {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 14px;
    font-size: 14px;
    font-family: inherit;
    color: var(--text);
    background: white;
    outline: none;
    transition: border-color 0.2s ease;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-soft); }
  textarea { resize: vertical; min-height: 120px; }
  .btn-submit {
    background: var(--brand);
    color: white;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s ease;
    box-shadow: 0 1px 3px rgba(70,120,220,0.3);
    align-self: flex-start;
  }
  .btn-submit:hover { background: var(--brand-dark); transform: translateY(-2px); }
  .btn-submit:disabled { opacity: 0.7; cursor: default; transform: none; }
  .form-privacy {
    font-size: 12px;
    color: var(--text-muted);
  }
  .form-privacy a { color: var(--brand); text-decoration: none; }

  .cf-hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .contact-form[hidden] { display: none; }
  .contact-success {
    text-align: center;
    padding: 48px 28px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--soft);
    outline: none;
  }
  .contact-success[hidden] { display: none; }
  .contact-success svg { color: var(--brand); margin-bottom: 14px; }
  .contact-success h3 { font-size: 20px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .contact-success p { font-size: 14px; color: var(--text-muted); line-height: 1.6; max-width: 420px; margin: 0 auto; }

  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; }
    .btn-submit { width: 100%; }
  }
</style>
