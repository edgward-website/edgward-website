---
import Base from '../layouts/Base.astro';
import { partners } from '../data/partners';
---

<Base
  title="Edgward — Sécurité à la demande en Suisse romande"
  description="Commandez une patrouille de sécurité en un clic. Disponible 24/7 en Suisse romande. Sans engagement, sans installation. Dès CHF 15/mois."
>

  <!-- HERO -->
  <section class="hero" id="particuliers">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="hero-badge-dot" aria-hidden="true"></span>
            Disponible en Suisse romande
          </div>
          <h1>Une patrouille<br>de sécurité<br>chez vous <em>en 1 clic</em>.</h1>
          <p>Un doute, une inquiétude, une urgence ? Commandez l'intervention d'un agent près de chez vous en un clic. Sans engagement, sans installation.</p>
          <div class="hero-ctas">
            <a href="#telecharger" class="btn-primary">
              Télécharger l'application
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="/comment-ca-marche" class="btn-secondary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              Voir la démo (60 s)
            </a>
          </div>
          <p class="hero-reassurance">1 mois d'essai gratuit · Résiliable à tout moment · Dès CHF 15/mois</p>
          <div class="hero-audiences" aria-label="Type de client">
            <a href="/particuliers" class="audience-card active">
              <div class="audience-title">Particuliers</div>
              <div class="audience-desc">Votre maison, vos proches, 24/7</div>
            </a>
            <a href="/entreprises" class="audience-card">
              <div class="audience-title">Entreprises</div>
              <div class="audience-desc">Locaux, chantiers, commerces</div>
            </a>
            <a href="/communes" class="audience-card">
              <div class="audience-title">Communes</div>
              <div class="audience-desc">Découvrez les possibilités</div>
            </a>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="ed-container">
            <div class="ed-halo"></div>
            <div class="ed-rings">
              <div class="ed-ring"></div>
              <div class="ed-ring"></div>
              <div class="ed-ring"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust" aria-label="Presse et évaluations">
    <div class="container">
      <div class="trust-inner">
        <div class="trust-label">Vu dans</div>
        <div class="trust-logos">
          <a href="/medias">RTS</a>
          <a href="/medias">Léman Bleu</a>
          <a href="/medias">Tribune de Genève</a>
          <a href="/medias">24heures</a>
        </div>
        <div class="trust-rating"><span class="star" aria-hidden="true">★</span> 4,8/5 · 240+ utilisateurs</div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section" id="comment-ca-marche">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-eyebrow">Comment ça marche</span>
        <h2>Sécurité à la demande<br>en <em>3 étapes</em></h2>
        <p class="section-subtitle">Aucune installation matérielle. Aucun engagement long terme.</p>
      </div>
      <div class="steps">
        <div class="step fade-in">
          <div class="step-num" aria-hidden="true">1</div>
          <h3>Abonnez-vous</h3>
          <p>Dès CHF 15/mois. Accédez à la plateforme et à notre réseau d’entreprises partenaires.</p>
        </div>
        <div class="step fade-in">
          <div class="step-num" aria-hidden="true">2</div>
          <h3>Configurez vos lieux</h3>
          <p>Adresse, consignes, boîtier à clés. Vos données restent sur votre téléphone et ne sont transmises qu'au moment de l'intervention.</p>
        </div>
        <div class="step fade-in">
          <div class="step-num" aria-hidden="true">3</div>
          <h3>Commandez en 1 clic</h3>
          <p>Choisissez la patrouille selon l’entreprise de votre choix, le prix ou le temps d’intervention. Suivez l’intervention en temps réel et recevez un rapport détaillé à la fin.</p>
        </div>
      </div>
      <div class="steps-cta fade-in">
        <a href="/comment-ca-marche" class="btn-ghost">En savoir plus sur le fonctionnement →</a>
      </div>
    </div>
  </section>

  <!-- PRICING PREVIEW -->
  <section class="section pricing-section" id="tarifs">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-eyebrow">Exemple concret</span>
        <h2>Combien ça coûte <em>vraiment</em> ?</h2>
        <p class="section-subtitle">Abonnement fixe + uniquement les interventions que vous demandez. Zéro frais caché.</p>
      </div>
      <div class="pricing-card fade-in">
        <div class="pricing-text">
          <h3>3× moins cher qu'un abonnement traditionnel de télésurveillance</h3>
          <p>Avec Edgward, pas d'installation à 2 000–6 000 CHF, pas d'engagement sur plusieurs années. Vous payez l'abonnement à la plateforme + les interventions réellement déclenchées, c'est tout.</p>
        </div>
        <div class="price-table" aria-label="Grille tarifaire indicative">
          <div class="price-row"><span class="label">Abonnement (base annuelle)</span><span class="value">CHF 12.5/mois</span></div>
          <div class="price-row"><span class="label">Intervention (prix moyen par intervention)</span><span class="value">~CHF 105 - CHF 170</span></div>
          <div class="price-highlight"><span>Essai gratuit</span><span>1 mois</span></div>
        </div>
        <p class="pricing-reassurance">Pas de frais cachés · Pas d'engagement · Votre sécurité à portée de clic</p>
      </div>
    </div>
  </section>

  <!-- SORAL + PARTNERS -->
  <section class="section" id="partenaires">
    <div class="container">
      <div class="soral fade-in">
        <img src="/assets/ed-pose.png" alt="" class="soral-ed" width="90" height="90" aria-hidden="true" loading="lazy">
        <div class="soral-text">
          <span class="soral-badge">★ Première commune partenaire</span>
          <h4>Soral subventionne Edgward pour ses habitants</h4>
          <p>Un modèle reproductible pour toutes les communes genevoises. Un montant de l’abonnement pris en charge par la commune. Sécurité de proximité sans charge opérationnelle.</p>
        </div>
        <a href="/communes" class="soral-cta">Découvrir le modèle communes →</a>
      </div>
      <p class="partners-title">Sélection d’entreprises de sécurité partenaires</p>
      <div class="partners-grid fade-in" aria-label="Partenaires sécurité">
        {partners.map(p => (
          <a href="/partenaires" class="partner" aria-label={p.name}>
            {p.logo
              ? <img src={p.logo} alt={p.name} class="partner-logo" loading="lazy" width="120" height="56">
              : <span class="partner-name">{p.name}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section testimonials-section">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-eyebrow">Témoignages</span>
        <h2>Ils font <em>confiance</em> à Edgward</h2>
      </div>
      <div class="testimonials">
        <article class="testimonial fade-in">
          <div class="testimonial-stars" aria-label="5 étoiles sur 5">★★★★★</div>
          <blockquote>« Intervention très rapide, l'agent m'a appelée une fois sur place pour me rassurer. Le sérieux d'une vraie entreprise de sécurité, la simplicité d'une app. »</blockquote>
          <footer class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">HT</div>
            <div>
              <div class="testimonial-name">Hélène T.</div>
              <div class="testimonial-role">Cologny GE</div>
            </div>
          </footer>
        </article>
        <article class="testimonial fade-in">
          <div class="testimonial-stars" aria-label="5 étoiles sur 5">★★★★★</div>
          <blockquote>« J'ai eu peur qu'il soit arrivé quelque chose à mon chien, j'ai demandé une intervention. Plus de peur que de mal, l'agent a été rapide et rassurant. »</blockquote>
          <footer class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">SC</div>
            <div>
              <div class="testimonial-name">Sandy C.</div>
              <div class="testimonial-role">Carouge GE</div>
            </div>
          </footer>
        </article>
        <article class="testimonial fade-in">
          <div class="testimonial-stars" aria-label="5 étoiles sur 5">★★★★★</div>
          <blockquote>« Des inconnus dans notre garage de Belmont. L'agent est intervenu à deux. Plus avantageux qu'un raccordement d'alarme classique. »</blockquote>
          <footer class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">MK</div>
            <div>
              <div class="testimonial-name">Mike K.</div>
              <div class="testimonial-role">Belmont VD</div>
            </div>
          </footer>
        </article>
      </div>
    </div>
  </section>

  <!-- B2B CARDS -->
  <section class="section" id="professionnels">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-eyebrow">Vous êtes un professionnel ?</span>
        <h2>Trois façons de <em>travailler avec Edgward</em></h2>
      </div>
      <div class="b2b-grid">
        <div class="b2b-card fade-in">
          <span class="b2b-eyebrow">Entreprises</span>
          <h3>Protégez locaux, chantiers, commerces</h3>
          <p>Pour les PME et grandes structures qui veulent une alternative flexible à la télésurveillance classique.</p>
          <ul class="b2b-features">
            <li>Pas d'installation</li>
            <li>Intervention à la demande</li>
            <li>Facturation transparente</li>
          </ul>
          <a href="/entreprises" class="btn-dark">Découvrir</a>
        </div>
        <div class="b2b-card featured fade-in">
          <span class="b2b-eyebrow">Communes</span>
          <h3>Sécurité de proximité pour vos habitants</h3>
          <p>Le modèle qui a séduit Soral : subventionnez l'abonnement pour vos habitants, sans aucune charge opérationnelle.</p>
          <ul class="b2b-features">
            <li>Montant de la subvention flexible</li>
            <li>Zéro gestion opérationnelle</li>
            <li>Pilotage budgétaire simple</li>
          </ul>
          <a href="/communes" class="btn-primary">Le modèle communes</a>
        </div>
        <div class="b2b-card fade-in">
          <span class="b2b-eyebrow">Centrales d'alarme</span>
          <h3>Déléguez vos levées de doute</h3>
          <p>Une centrale traite et envoie la patrouille la plus proche parmi les entreprises disponibles.</p>
          <ul class="b2b-features">
            <li>Intégration simple</li>
            <li>Définissez le montant maximum de l’intervention</li>
            <li>Rapport automatique</li>
          </ul>
          <a href="/entreprises#centrales" class="btn-dark">En savoir plus</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA / DOWNLOAD -->
  <section class="final-cta" id="telecharger">
    <div class="container">
      <div class="final-grid">
        <img src="/assets/ed-pouce.png" alt="" class="final-ed" width="180" height="180" aria-hidden="true" loading="lazy">
        <div class="final-left">
          <h2>Prêt à confier votre sécurité<br>à <em>Ed et son équipe</em> ?</h2>
          <p>Téléchargez l'application et testez gratuitement pendant 1 mois. Résiliable à tout moment, sans frais.</p>
          <div class="stores">
            <a href="https://apps.apple.com/ch/app/edgward/id6503622410" class="store-btn" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              <div>
                <span class="store-sub">Télécharger sur</span>
                <span class="store-main">App Store</span>
              </div>
            </a>
            <a href="https://play.google.com/store/apps/details?id=ch.edgward.app.clients" class="store-btn" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.19l2.807 1.626a1 1 0 010 1.73l-2.808 1.626-2.496-2.491 2.497-2.491zM5.864 2.658L16.802 8.99l-2.302 2.302-8.636-8.634z"/></svg>
              <div>
                <span class="store-sub">Disponible sur</span>
                <span class="store-main">Google Play</span>
              </div>
            </a>
          </div>
        </div>
        <div class="email-card">
          <div class="email-default" id="email-capture-default">
            <h4>Pas encore prêt ?</h4>
            <p>Téléchargez gratuitement notre guide « Sécuriser son domicile ».</p>
            <form class="email-form" id="email-capture" novalidate>
              <input type="email" name="EMAIL" placeholder="votre@email.ch" aria-label="Votre adresse email" autocomplete="email" required>
              <input type="text" name="email_address_check" value="" tabindex="-1" autocomplete="off" aria-hidden="true" class="email-hp">
              <button type="submit">Recevoir</button>
            </form>
            <p class="email-privacy">En vous inscrivant, vous acceptez notre <a href="/confidentialite">politique de confidentialité</a>.</p>
          </div>
          <div class="email-success" id="email-capture-success" hidden>
            <h4>Merci&nbsp;!</h4>
            <p>Votre guide « Sécuriser son domicile » est prêt à télécharger.</p>
            <a href="/assets/guide-securiser-son-domicile.pdf" download class="email-download">
              Télécharger le guide
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 3v12m0 0l-5-5m5 5l5-5M5 21h14"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<script>
  const form = document.getElementById('email-capture') as HTMLFormElement | null;
  const defaultBox = document.getElementById('email-capture-default');
  const successBox = document.getElementById('email-capture-success');
  const BREVO_ACTION = 'https://87714af1.sibforms.com/serve/MUIFAMrrWdxPBYrsJbVl3DEx2xLkeG0iVWB5XkCoCcZ22ARhk_U-AcqM-P-P1NLYOuD2EH-OCwsPhS2Wwh-tKXHv36Va4XMMimuN2LOwPbVFNIP6mpmrNr1rga5vuBAxweX_kAFYUbz6_lpfaMZREUftQYz6VOiO2LSXfcpcjqLFyrGdOBWBAfnvmeBotpNVxMQDfQSnDaVHxwYB';
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const honeypot = (form.elements.namedItem('email_address_check') as HTMLInputElement)?.value;
    if (honeypot) return;
    const input = form.querySelector('input[type="email"]') as HTMLInputElement;
    const email = input.value.trim();
    if (!input.validity.valid || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
      input.focus();
      input.reportValidity();
      return;
    }
    const btn = form.querySelector('button') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Envoi…';
    const params = new URLSearchParams();
    params.append('EMAIL', email);
    params.append('email_address_check', '');
    params.append('locale', 'en');
    fetch(BREVO_ACTION, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: params,
      keepalive: true,
    }).catch(() => {});
    if (defaultBox) defaultBox.hidden = true;
    if (successBox) {
      successBox.hidden = false;
      (successBox.querySelector('.email-download') as HTMLAnchorElement | null)?.focus();
    }
  });
</script>

<style>
  /* HERO */
  .hero { background: var(--navy); color: white; padding: 72px 0 56px; overflow: hidden; position: relative; }
  .hero::before { content: ''; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .hero::after { content: ''; position: absolute; bottom: -200px; left: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(70,120,220,0.1) 0%, transparent 70%); pointer-events: none; }
  .hero-grid { display: grid; grid-template-columns: 1.25fr 1fr; gap: 48px; align-items: center; position: relative; z-index: 2; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-soft); color: var(--brand-light); padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); margin-bottom: 22px; }
  .hero-badge-dot { width: 7px; height: 7px; background: var(--brand-light); border-radius: 50%; animation: pulse 2s infinite; }
  .hero h1 { font-size: clamp(38px, 5vw, 58px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); letter-spacing: -0.01em; }
  .hero p { font-size: 17px; line-height: 1.6; color: #cbd5e1; margin-bottom: 30px; max-width: 520px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
  .hero-reassurance { font-size: 13px; color: #94a3b8; margin-bottom: 32px; }
  .hero-audiences { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 14px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .audience-card { padding: 12px 14px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); cursor: pointer; transition: all 0.2s ease; background: none; text-align: left; font-family: inherit; color: inherit; text-decoration: none; }
  .audience-card:hover { background: rgba(255,255,255,0.05); transform: translateY(-2px); }
  .audience-card.active { background: var(--brand-soft); border-color: rgba(70,120,220,0.5); }
  .audience-card.active .audience-title { color: var(--brand-light); }
  .audience-title { font-size: 13px; font-weight: 600; color: white; margin-bottom: 3px; }
  .audience-desc { font-size: 11px; color: #94a3b8; line-height: 1.4; }

  /* HERO VISUAL */
  .hero-visual { position: relative; display: flex; align-items: center; justify-content: center; min-height: 440px; }
  .ed-container { position: relative; width: 100%; max-width: 360px; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; }
  .ed-halo { position: absolute; top: 50%; left: 50%; width: 120%; height: 120%; transform: translate(-50%,-50%); background: radial-gradient(circle, var(--brand-glow) 0%, transparent 55%); pointer-events: none; }
  .ed-rings { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 100%; aspect-ratio: 1; pointer-events: none; }
  .ed-ring { position: absolute; top: 50%; left: 50%; border: 1.5px solid rgba(107,147,232,0.3); border-radius: 50%; transform: translate(-50%,-50%); animation: ring-pulse 3s ease-out infinite; }
  .ed-ring:nth-child(1) { width: 60%; height: 60%; animation-delay: 0s; }
  .ed-ring:nth-child(2) { width: 80%; height: 80%; animation-delay: 1s; }
  .ed-ring:nth-child(3) { width: 100%; height: 100%; animation-delay: 2s; }

  /* TRUST */
  .trust { background: var(--soft); border-bottom: 1px solid var(--border); padding: 18px 0; }
  .trust-inner { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
  .trust-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }
  .trust-logos { display: flex; gap: 32px; font-size: 15px; font-weight: 700; color: var(--text-light); letter-spacing: -0.02em; align-items: center; }
  .trust-logos a { transition: color 0.2s ease; text-decoration: none; color: inherit; }
  .trust-logos a:hover { color: var(--text); }
  .trust-rating { font-size: 13px; color: var(--navy); font-weight: 600; }
  .star { color: var(--brand); }

  /* STEPS */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; position: relative; }
  .steps::before { content: ''; position: absolute; top: 32px; left: 12%; right: 12%; height: 1px; background: linear-gradient(to right, transparent 0%, var(--border) 20%, var(--border) 80%, transparent 100%); z-index: 0; }
  .step { background: white; padding: 8px; position: relative; z-index: 1; }
  .step-num { width: 64px; height: 64px; background: var(--navy); color: var(--brand-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 400; margin: 0 auto 24px; font-family: 'Instrument Serif', Georgia, serif; font-style: italic; border: 3px solid white; box-shadow: 0 0 0 1px var(--border); }
  .step h3 { font-size: 20px; font-weight: 700; color: var(--navy); margin-bottom: 10px; text-align: center; letter-spacing: -0.01em; }
  .step p { font-size: 15px; color: var(--text-muted); line-height: 1.6; text-align: center; }
  .steps-cta { text-align: center; margin-top: 40px; }

  /* PRICING */
  .pricing-section { background: var(--soft); }
  .pricing-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 40px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; max-width: 980px; margin: 0 auto; }
