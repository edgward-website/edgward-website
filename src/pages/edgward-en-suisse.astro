---
import Base from '../layouts/Base.astro';
import CoverageMap from '../components/CoverageMap.astro';
import PartnersGrid from '../components/PartnersGrid.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionHeader from '../components/SectionHeader.astro';

const deploymentCards = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    title: 'Qualité avant quantité',
    description: 'Chaque partenaire sécurité est sélectionné selon des critères stricts : certifications, équipement, délai d\'intervention, et évaluations terrain. Nous préférons moins de cantons mais un service irréprochable.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    title: 'Couverture réelle',
    description: 'Un canton est déclaré "couvert" uniquement lorsque l’ensemble des communes sont couvertes par au moins un partenaire de sécurité. Pas de couverture partielle affichée comme complète.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>',
    title: 'Croissance maîtrisée',
    description: 'L\'extension géographique suit la disponibilité de partenaires qualifiés et la demande locale. Fribourg et le Valais sont en cours de déploiement ; le Jura est la prochaine priorité.',
  },
];

const partners = [
  { name: 'GPA SA', accent: 'Genève · Vaud · Neuchâtel' },
  { name: 'Global Sécurité (SPS)', accent: 'Arc lémanique' },
  { name: 'Python Sécurité SA', accent: 'Genève' },
  { name: 'Sécurice', accent: 'Neuchâtel' },
  { name: 'Juggers', accent: 'Genève · Vaud' },
  { name: 'Alpshawk', accent: 'Vaud' },
  { name: 'Wolfguard', accent: 'Genève' },
  { name: 'Roc Sécurité', accent: 'Valais' },
  { name: 'KRK Security', accent: 'Fribourg' },
];
---

<Base
  title="Edgward en Suisse — Couverture territoriale | Edgward"
  description="Découvrez la couverture territoriale d'Edgward en Suisse romande. Genève, Vaud et Neuchâtel complètement couverts. Fribourg et Valais en déploiement."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <span class="hero-eyebrow">Couverture territoriale</span>
        <h1>Edgward dans toute la <em>Suisse romande</em></h1>
        <p>Service d'intervention sécuritaire à la demande, déployé progressivement à travers les cantons romands. Genève, Vaud et Neuchâtel sont pleinement couverts.</p>
      </div>
    </div>
  </section>

  <!-- CARTE INTERACTIVE -->
  <section class="map-section">
    <div class="container">
      <CoverageMap />
    </div>
  </section>

  <!-- POURQUOI CETTE PROGRESSION -->
  <section class="section why-section">
    <div class="container">
      <SectionHeader
        eyebrow="Notre approche"
        title="Pourquoi cette <em>progression</em> ?"
        subtitle="Edgward déploie son réseau de façon méthodique pour garantir un service fiable à chaque étape."
        align="center"
      />
      <div class="why-grid">
        {deploymentCards.map(card => (
          <div class="why-card">
            <div class="why-icon" set:html={card.icon} />
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TODO: valider liste et zones des partenaires avec l'équipe -->
  <!-- PARTENAIRES PAR ZONE -->
  <PartnersGrid
    title="Nos partenaires sécurité agréés"
    partners={partners}
  />

  <!-- VOTRE CANTON N'EST PAS COUVERT -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-text">
          <span class="eyebrow-tag">Vous n'êtes pas encore couvert ?</span>
          <h2>Faites-le nous savoir</h2>
          <p>Chaque demande compte pour prioriser le déploiement. Si votre canton n'est pas encore couvert, signalez-nous votre intérêt — cela accélère concrètement notre expansion dans votre région.</p>
          <ul class="cta-benefits">
            <li>
              <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Nous vous prévenons dès que votre région est couverte
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Votre demande accélère le déploiement
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Aucun engagement de votre côté
            </li>
          </ul>
        </div>
        <div class="cta-form">
          <ContactForm defaultSubject="Demande de couverture" />
        </div>
      </div>
    </div>
  </section>

  <FinalCTA
    title="Disponible maintenant dans <em>votre région</em>"
    description="Téléchargez l'app et vérifiez si votre adresse est couverte en quelques secondes."
  />
</Base>

<style>
  /* HERO */
  .hero {
    background: var(--navy); color: white;
    padding: 72px 0 56px; text-align: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute;
    top: -200px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
  .hero-eyebrow {
    display: inline-block; font-size: 12px; color: var(--brand-light);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px;
  }
  .hero h1 {
    font-size: clamp(32px, 4vw, 52px); font-weight: 800; line-height: 1.1;
    letter-spacing: -0.025em; margin-bottom: 20px; color: white;
  }
  .hero h1 em {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic; font-weight: 400; color: var(--brand-light);
  }
  .hero p { font-size: 17px; color: #cbd5e1; line-height: 1.6; max-width: 520px; margin: 0 auto; }

  /* MAP */
  .map-section { background: var(--soft); padding: 56px 0; }

  /* WHY */
  .why-section { background: white; }
  .why-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px; margin-top: 40px;
  }
  .why-card {
    background: var(--soft); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 28px;
  }
  .why-icon {
    width: 44px; height: 44px; color: var(--brand);
    margin-bottom: 16px;
  }
  .why-icon :global(svg) { width: 100%; height: 100%; }
  .why-card h3 { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
  .why-card p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

  /* CTA SECTION */
  .cta-section { background: var(--soft); }
  .cta-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: start;
  }
  .eyebrow-tag {
    display: inline-block; font-size: 11px; font-weight: 700;
    color: var(--brand); text-transform: uppercase; letter-spacing: 0.1em;
    background: var(--brand-soft); padding: 4px 12px; border-radius: 100px;
    margin-bottom: 16px;
  }
  .cta-text h2 {
    font-size: clamp(26px, 2.5vw, 36px); font-weight: 800; color: var(--navy);
    letter-spacing: -0.025em; margin-bottom: 16px; line-height: 1.15;
  }
  .cta-text p { font-size: 16px; color: var(--text-muted); line-height: 1.7; margin-bottom: 24px; }
  .cta-benefits { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .cta-benefits li {
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; color: var(--text); font-weight: 500;
  }
  .cta-benefits li svg { color: #10b981; flex-shrink: 0; }

  @media (max-width: 900px) {
    .why-grid { grid-template-columns: 1fr; }
    .cta-inner { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
