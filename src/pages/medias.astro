---
import Base from '../layouts/Base.astro';
import MediaCard from '../components/MediaCard.astro';
import SectionHeader from '../components/SectionHeader.astro';

const articles = [
  {
    mediaName: 'RTS',
    date: 'Juillet 2024',
    excerpt: "Une app genevoise propose un service de sécurité sur demande, permettant d'obtenir l'intervention d'un agent de sécurité en quelques minutes via une application mobile.",
    url: 'https://www.rts.ch/info/suisse/2024/article/une-app-pour-un-service-de-securite-sur-demande-l-innovation-d-une-societe-genevoise-28584537.html',
    type: 'article',
  },
  {
    mediaName: 'Léman Bleu',
    date: 'Juillet 2024',
    excerpt: "Une plateforme genevoise veut révolutionner la sécurité privée en mettant en relation directe les particuliers et les entreprises de sécurité agréées.",
    url: 'https://www.lemanbleu.ch/fr/Actualites/Geneve/Une-plateforme-genevoise-veut-revolutionner-la-securite-privee.html',
    type: 'video',
  },
  {
    mediaName: 'Tribune de Genève',
    date: 'Janvier 2025',
    excerpt: "La commune de Soral noue un partenariat avec Edgward, une application de sécurité privée à la demande. Une première en Suisse pour une commune.",
    url: 'https://www.tdg.ch/geneve-soral-collabore-avec-une-societe-de-securite-privee-806996337368',
    type: 'article',
  },
  {
    mediaName: 'Radio Lac',
    date: 'Février 2025',
    excerpt: "Et si le futur de la sécurité privée passait par la demande ? Edgward propose une alternative innovante aux systèmes de télésurveillance classiques.",
    url: 'https://www.radiolac.ch/publireportage/et-si-le-futur-passait-par-la-securite-a-la-demande/',
    type: 'radio',
  },
  {
    mediaName: '24 heures',
    date: '[TODO: date à confirmer]',
    excerpt: "[TODO: extrait à récupérer]",
    url: '#',
    type: 'article',
  },
];
---

<Base
  title="Espace presse — Edgward dans les médias"
  description="Retrouvez toutes les apparitions d'Edgward dans la presse. Tribune de Genève, RTS, 24heures, Léman Bleu et plus encore."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <span class="hero-eyebrow">Espace presse</span>
        <h1>Edgward dans <em>les médias</em></h1>
        <p>Retrouvez nos apparitions dans la presse et les sujets qui parlent d'Edgward.</p>
      </div>
    </div>
  </section>

  <!-- MEDIA CARDS -->
  <section class="section media-section">
    <div class="container">
      <SectionHeader
        eyebrow="Revue de presse"
        title="Ils parlent de <em>nous</em>"
      />
      <div class="media-grid">
        {articles.map(article => (
          <MediaCard
            mediaName={article.mediaName}
            date={article.date}
            excerpt={article.excerpt}
            url={article.url}
            type={article.type as 'article' | 'radio' | 'video'}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- PRESS CONTACT -->
  <section class="section press-contact-section">
    <div class="container">
      <div class="press-block fade-in">
        <h3>Contact presse</h3>
        <p>Pour toute demande d'interview, de visuels ou d'information supplémentaire</p>
        <a href="mailto:info@edgward.ch" class="press-email">info@edgward.ch</a>
        <p class="press-kit-note">Kit média disponible sur demande (logos, photos, biographie des fondateurs).</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: var(--navy); color: white;
    padding: 72px 0 56px; text-align: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute;
    top: -200px; left: 50%; transform: translateX(-50%);
    width: 500px; height: 500px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }
  .hero-eyebrow { display: inline-block; font-size: 12px; color: var(--brand-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; }
  .hero h1 { font-size: clamp(34px, 4vw, 50px); font-weight: 800; line-height: 1.1; letter-spacing: -0.025em; margin-bottom: 16px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero p { font-size: 17px; color: #cbd5e1; line-height: 1.6; }

  .media-section { background: white; }
  .media-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* PRESS CONTACT */
  .press-contact-section { background: var(--soft); }
  .press-block {
    max-width: 600px; margin: 0 auto;
    background: white; border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 36px;
    text-align: center;
  }
  .press-block h3 { font-size: 20px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .press-block > p { font-size: 15px; color: var(--text-muted); margin-bottom: 16px; }
  .press-email {
    display: inline-block;
    font-size: 18px; font-weight: 700;
    color: var(--brand); text-decoration: none;
    margin-bottom: 28px;
    transition: color 0.15s ease;
  }
  .press-email:hover { color: var(--brand-dark); }
  .press-kit-note { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; line-height: 1.5; }
  .press-assets { text-align: center; }
  .assets-label { display: block; font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 12px; }
  .assets-tags { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
  .tag {
    background: var(--soft); border: 1px solid var(--border);
    border-radius: 100px; padding: 6px 14px;
    font-size: 12px; color: var(--text-muted); font-weight: 500;
  }

  @media (max-width: 1024px) {
    .media-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .media-grid { grid-template-columns: 1fr; }
  }
</style>
