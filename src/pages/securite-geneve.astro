---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FinalCTA from '../components/FinalCTA.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import Testimonials from '../components/Testimonials.astro';
import PartnersGrid from '../components/PartnersGrid.astro';
import { partners } from '../data/partners';

// Partenaires actifs sur le canton de Genève (sous-ensemble du réseau).
const geneveNames = ['GPA SA', 'Python Sécurité SA', 'KRK Security', 'Global Sécurité (SPS)'];
const partenairesGE = partners.filter(p => geneveNames.includes(p.name));

// Chiffres officiels - Statistique policière de la criminalité 2025, police cantonale genevoise (ge.ch).
const contexte = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M19 9l-5 5-4-4-3 3"/></svg>',
    title: 'La criminalité recule globalement',
    description: "En 2025, le canton de Genève a enregistré 50'020 infractions au Code pénal, contre 52'146 en 2024 - un recul de 4%. Une bonne nouvelle d'ensemble.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V8l7-5 7 5v13"/><path d="M9 21v-6h6v6"/></svg>',
    title: 'Mais les cambriolages augmentent',
    description: "Les vols par effraction et introduction clandestine progressent de 7%, passant de 3'196 à 3'410 cas. La tendance va à contre-courant de la baisse générale.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10h18M6 10V6a2 2 0 012-2h8a2 2 0 012 2v4M5 10v10h14V10"/><path d="M10 15h4"/></svg>',
    title: 'Les caves, première cible',
    description: "Les cambriolages de caves d'immeubles bondissent de 65% (668 cas), et les home-jackings sont aussi en hausse. Les habitations restent exposées.",
  },
];

const solution = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3"/></svg>',
    title: 'Savoir - alertes géolocalisées',
    description: "Suivez ce qui se passe réellement dans votre quartier genevois : signalements vérifiés, modérés, rattachés à votre localité. L'essentiel, sans le bruit des groupes WhatsApp.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 9l4.5 11 1.7-4.8 4.8-1.7z"/><path d="M7.5 2.7 8.2 5M5 7.5 2.7 6.8M13.3 4.7 11.6 6.4M6.4 11.6 4.7 13.3"/></svg>',
    title: 'Agir - intervention à la demande',
    description: "Une situation vous préoccupe ? Commandez une patrouille d'un de nos partenaires genevois en quelques secondes. Délai moyen d'intervention : 10 à 15 minutes.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>',
    title: 'Sans engagement',
    description: "Pas d'abonnement de longue durée ni de contrat contraignant. Vous activez Edgward quand vous en avez besoin, sur tout le canton de Genève.",
  },
];

const usages = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>',
    title: 'Vous habitez Genève',
    description: "Des Eaux-Vives à Carouge, suivez l'activité autour de chez vous et renforcez votre sécurité au bon moment - avant les vacances ou après un signalement suspect.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h1m4 0h1M9 13h1m4 0h1M9 17h1m4 0h1"/></svg>',
    title: 'Vous dirigez un commerce ou une entreprise',
    description: "Protégez vos locaux et vos équipes en ville comme en zone industrielle. Information vérifiée et intervention à la demande, sans agent posté à demeure.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l9-9 9 9M5 10v10h14V10M9 21v-6h6v6"/></svg>',
    title: 'Vous possédez une villa ou un bien',
    description: "Caves, villas, résidences : les cibles les plus touchées en 2025. Recevez les alertes de votre secteur et faites intervenir une patrouille en cas de doute.",
  },
];

const temoignages = [
  {
    quote: "Le module d'alertes et informations est super utile.",
    name: 'Caroline M.',
    role: 'Utilisatrice à Genève',
    initials: 'CM',
  },
  {
    quote: "Intervention rapide et agent très sympa, merci !",
    name: 'Emmanuelle F.',
    role: 'Cliente à Genève',
    initials: 'EF',
  },
  {
    quote: "Je n'étais pas sûr de qui traînait dans mon jardin, les agents ont été bien réactifs, top.",
    name: 'Marc M.',
    role: 'Client à Genève',
    initials: 'MM',
  },
];

// Communes classées par importance (population / recherches Google), les plus grandes en tête.
// href = lien vers la page locale dédiée (maillage interne) quand elle existe.
const communes = [
  { name: 'Genève' },
  { name: 'Vernier' },
  { name: 'Lancy', href: '/securite-lancy' },
  { name: 'Meyrin' },
  { name: 'Carouge', href: '/securite-carouge' },
  { name: 'Onex', href: '/securite-onex' },
  { name: 'Thônex', href: '/securite-thonex' },
  { name: 'Chêne-Bougeries', href: '/securite-chene-bougeries' },
  { name: 'Veyrier', href: '/securite-veyrier' },
  { name: 'Plan-les-Ouates', href: '/securite-plan-les-ouates' },
  { name: 'Pregny-Chambésy', href: '/securite-pregny-chambesy' },
  { name: 'Versoix' },
  { name: 'Le Grand-Saconnex' },
  { name: 'Bernex' },
  { name: 'Cologny' },
];
---

<Base
  title="Sécurité à Genève : alertes et intervention à la demande | Edgward"
  description="Comprenez ce qui se passe près de chez vous à Genève et faites intervenir une patrouille en 10-15 min. Alertes géolocalisées vérifiées et sécurité à la demande sur tout le canton."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="hero-badge">
            <svg class="canton-flag" width="20" height="14" viewBox="0 0 20 14" aria-hidden="true"><rect width="20" height="14" rx="2.5" fill="#f4c300"/><path d="M10 0 H17.5 A2.5 2.5 0 0 1 20 2.5 V11.5 A2.5 2.5 0 0 1 17.5 14 H10 Z" fill="#d8232a"/><g fill="#f4c300"><circle cx="15" cy="4.3" r="1.6"/><rect x="14.35" y="5.2" width="1.3" height="6" rx="0.5"/><rect x="15.5" y="8.4" width="1.8" height="1.1" rx="0.3"/><rect x="15.5" y="10.1" width="1.3" height="1.1" rx="0.3"/></g><circle cx="15" cy="4.3" r="0.6" fill="#d8232a"/></svg>
            Canton de Genève
          </div>
          <h1>La sécurité à Genève,<br><em>sans laisser au hasard</em></h1>
          <p>Comprendre ce qui se passe autour de vous <strong>et</strong> pouvoir agir immédiatement si besoin - au même endroit, sur tout le canton. Alertes géolocalisées vérifiées et intervention d'une patrouille à la demande.</p>
          <div class="hero-ctas">
            <a href="#telecharger" class="btn-primary">
              Découvrir dans l'app
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="#solution" class="btn-secondary">
              Comment ça marche
            </a>
          </div>
          <p class="hero-note">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Découvrez le <a href="/alertes">module Alertes &amp; Informations</a> ou nos solutions pour <a href="/entreprises">entreprises</a>.
          </p>
        </div>
        <div class="hero-visual">
          <div class="newsfeed-demo" aria-label="Exemple d'alertes à Genève">
            <div class="demo-header">
              <span class="demo-title">Alertes · Genève</span>
              <span class="demo-radius">1 km</span>
            </div>
            <div class="demo-item demo-item--red">
              <div class="demo-dot demo-dot--red"></div>
              <div class="demo-content">
                <strong>Cambriolage de cave signalé</strong>
                <span>Eaux-Vives · il y a 35 min</span>
              </div>
              <a href="/alertes" class="demo-cta">Intervenir</a>
            </div>
            <div class="demo-item demo-item--orange">
              <div class="demo-dot demo-dot--orange"></div>
              <div class="demo-content">
                <strong>Véhicule suspect</strong>
                <span>Carouge · il y a 2h</span>
              </div>
            </div>
            <div class="demo-item demo-item--yellow">
              <div class="demo-dot demo-dot--yellow"></div>
              <div class="demo-content">
                <strong>Tentative d'intrusion</strong>
                <span>Champel · il y a 4h</span>
              </div>
            </div>
            <div class="demo-item">
              <div class="demo-dot demo-dot--green"></div>
              <div class="demo-content">
                <strong>Patrouille passée ✓</strong>
                <span>Plainpalais · il y a 6h</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTEXTE -->
  <section class="section problem-section" id="contexte">
    <div class="container">
      <SectionHeader
        eyebrow="Le contexte genevois"
        title="À Genève, la criminalité recule - <em>mais pas l'effraction</em>"
        subtitle="Les chiffres officiels 2025 racontent une histoire en deux temps : une baisse générale rassurante, mais une pression accrue sur les cambriolages et les habitations."
      />
      <BenefitsGrid benefits={contexte} cols={3} />
      <p class="source-note">
        Source : Statistique policière de la criminalité 2025, police cantonale genevoise -
        <a href="https://www.ge.ch/document/criminalite-geneve-recul-marque-2025-au-dela-moyennes-nationales" target="_blank" rel="noopener">ge.ch</a>.
      </p>
    </div>
  </section>

  <!-- SOLUTION -->
  <section class="section solution-section" id="solution">
    <div class="container">
      <SectionHeader
        eyebrow="Notre solution"
        title="Savoir ce qui se passe, <em>et pouvoir agir</em>"
        subtitle="Edgward réunit deux choses au même endroit : l'information de sécurité fiable de votre quartier, et la possibilité de déclencher une intervention quand vous en avez besoin."
      />
      <BenefitsGrid benefits={solution} cols={3} />
    </div>
  </section>

  <!-- COUVERTURE -->
  <section class="section coverage-section" id="couverture">
    <div class="container">
      <SectionHeader
        eyebrow="Couverture"
        title="Tout le canton de Genève, <em>couvert</em>"
        subtitle="Edgward s'appuie sur un réseau de sociétés de sécurité genevoises pour intervenir partout dans le canton, en ville comme en périphérie."
      />
      <div class="coverage-stats">
        <div class="cstat">
          <span class="cstat-num">10-15 min</span>
          <span class="cstat-label">délai moyen d'intervention</span>
        </div>
        <div class="cstat">
          <span class="cstat-num">Tout le canton</span>
          <span class="cstat-label">de la rive gauche à la rive droite</span>
        </div>
        <div class="cstat">
          <span class="cstat-num">Sans engagement</span>
          <span class="cstat-label">à la demande, quand vous le décidez</span>
        </div>
      </div>
      <ul class="communes" aria-label="Communes couvertes à Genève">
        {communes.map(c => <li>{c.href ? <a href={c.href}>{c.name}</a> : c.name}</li>)}
        <li class="communes-more">…et toutes les autres communes genevoises</li>
      </ul>
    </div>
  </section>

  <!-- USAGES -->
  <section class="section usecases-section" id="usages">
    <div class="container">
      <SectionHeader
        eyebrow="Pour qui ?"
        title="Que vous soyez résident, commerçant <em>ou propriétaire</em>"
      />
      <BenefitsGrid benefits={usages} cols={3} />
    </div>
  </section>

  <!-- CONFIANCE -->
  <section class="section trust-section" id="confiance">
    <div class="container">
      <SectionHeader
        eyebrow="Ils nous font confiance"
        title="Des Genevois·es <em>déjà protégé·es</em>"
      />
      <Testimonials items={temoignages} />
    </div>
  </section>

  <PartnersGrid
    title="Nos sociétés de sécurité partenaires à Genève"
    partners={partenairesGE}
  />

  <!-- FINAL CTA -->
  <FinalCTA
    title="Reprenez le contrôle de <em>votre sécurité à Genève</em>"
    description="Téléchargez Edgward et activez les alertes de votre quartier dès aujourd'hui. Information vérifiée et intervention à la demande, sur tout le canton."
    appStoreUrl="https://apps.apple.com/ch/app/edgward/id6503622410"
    playStoreUrl="https://play.google.com/store/apps/details?id=ch.edgward.app.clients"
  />
</Base>

<style>
  .hero { background: var(--navy); color: white; padding: 72px 0 56px; overflow: hidden; position: relative; }
  .hero::before { content: ''; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center; position: relative; z-index: 2; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-soft); color: var(--brand-light); padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); margin-bottom: 22px; }
  .hero-badge-dot { width: 7px; height: 7px; background: var(--brand-light); border-radius: 50%; animation: pulse 2s infinite; }
  .canton-flag { border-radius: 3px; box-shadow: 0 0 0 1px rgba(255,255,255,0.3); flex-shrink: 0; display: block; }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.2); } }
  .hero h1 { font-size: clamp(36px, 4.5vw, 54px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero-content > p { font-size: 17px; line-height: 1.6; color: #cbd5e1; margin-bottom: 30px; max-width: 520px; }
  .hero-content > p strong { color: white; font-weight: 700; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-note { margin-top: 20px; font-size: 14px; line-height: 1.55; color: #cbd5e1; max-width: 480px; }
  .hero-note svg { color: var(--brand-light); vertical-align: -2px; margin-right: 6px; }
  .hero-note a { color: var(--brand-light); text-decoration: underline; text-underline-offset: 3px; font-weight: 600; }
  .hero-note a:hover { color: white; }

  /* NEWSFEED DEMO */
  .hero-visual { display: flex; align-items: center; justify-content: center; min-height: 380px; }
  .newsfeed-demo { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: var(--radius-lg); padding: 20px; width: 100%; max-width: 360px; display: flex; flex-direction: column; gap: 10px; }
  .demo-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
  .demo-title { font-size: 13px; font-weight: 600; color: white; }
  .demo-radius { font-size: 11px; color: var(--brand-light); background: var(--brand-soft); padding: 2px 8px; border-radius: 100px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); }
  .demo-item { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.04); border-radius: 8px; padding: 10px 12px; border: 1px solid rgba(255,255,255,0.06); }
  .demo-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .demo-dot--red { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.6); }
  .demo-dot--orange { background: #f97316; box-shadow: 0 0 6px rgba(249,115,22,0.6); }
  .demo-dot--yellow { background: #eab308; }
  .demo-dot--green { background: #22c55e; }
  .demo-content { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .demo-content strong { font-size: 12px; color: white; font-weight: 600; }
  .demo-content span { font-size: 10px; color: #94a3b8; }
  .demo-cta { background: var(--brand); color: white; border: none; border-radius: 6px; font-size: 11px; font-weight: 600; padding: 4px 10px; cursor: pointer; font-family: inherit; white-space: nowrap; transition: background 0.2s ease; text-decoration: none; display: inline-block; }
  .demo-cta:hover { background: var(--brand-dark); }

  .problem-section { background: white; }
  .solution-section { background: var(--soft); }
  .coverage-section { background: white; }
  .usecases-section { background: var(--soft); }
  .trust-section { background: white; }

  /* SOURCE NOTE */
  .source-note { text-align: center; font-size: 13px; color: var(--text-muted); margin-top: 28px; }
  .source-note a { color: var(--brand); text-decoration: underline; text-underline-offset: 2px; }

  /* COVERAGE */
  .coverage-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 36px; }
  .cstat { background: var(--soft); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px 24px; text-align: center; }
  .cstat-num { display: block; font-size: 26px; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; margin-bottom: 6px; }
  .cstat-label { display: block; font-size: 13px; color: var(--text-muted); line-height: 1.4; }
  .communes { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
  .communes li { background: var(--soft); border: 1px solid var(--border); border-radius: 100px; padding: 7px 16px; font-size: 13px; font-weight: 600; color: var(--navy); transition: all 0.15s ease; }
  .communes li:has(a) { border-color: rgba(70,120,220,0.35); }
  .communes li:has(a):hover { background: var(--brand-soft); border-color: var(--brand); }
  .communes li a { color: var(--brand); text-decoration: none; }
  .communes-more { background: transparent !important; border: none !important; color: var(--text-muted) !important; font-weight: 400 !important; font-style: italic; }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { order: -1; }
  }
  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
    .coverage-stats { grid-template-columns: 1fr; }
  }
</style>
