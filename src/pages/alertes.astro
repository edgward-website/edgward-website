---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FinalCTA from '../components/FinalCTA.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import EdSonar from '../components/EdSonar.astro';

const problems = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
    title: 'Caméras : vous êtes seul face à l\'info',
    description: "Votre caméra enregistre — mais elle n'alerte personne d'autre. Vous êtes seul à analyser, seul à décider. Et si vous n'êtes pas là ?",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>',
    title: 'Presse locale : trop tard, trop générique',
    description: "Les faits divers paraissent des heures après les événements, sans localisation précise. Impossible de savoir si ça s'est passé à 200m de chez vous.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    title: 'Bouche-à-oreille : incertain et partiel',
    description: "Les groupes WhatsApp de quartier sont bruyants, peu filtrés, et souvent inexacts. L'information utile se noie dans le bruit.",
  },
];

const solution = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>',
    title: 'Événements géolocalisés',
    description: "Chaque alerte est rattachée à une position précise. Vous définissez votre rayon (500m, 1km, 2km) et ne recevez que ce qui se passe dans votre zone.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    title: 'Sources vérifiées',
    description: "Les signalements sont croisés et modérés avant diffusion. Pas de rumeurs, pas de panique inutile — seulement les informations qui méritent votre attention.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    title: 'Action en un clic',
    description: "Une alerte vous préoccupe ? Commandez directement une intervention depuis le fil. L'agent le plus proche reçoit votre demande en temps réel.",
  },
];

const useCases = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>',
    title: 'Avant de partir en vacances',
    description: "Consultez le fil des 30 derniers jours dans votre quartier. Si l'activité est élevée, renforcez votre sécurité avant de partir.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>',
    title: 'Après une alerte suspecte',
    description: "Un voisin signale un rodeur ? Vérifiez l'étendue du signalement et décidez en connaissance de cause si une intervention est utile.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    title: 'Pour votre résidence secondaire',
    description: "Recevez les alertes autour de votre chalet ou appartement de vacances — même quand vous êtes en ville.",
  },
];
---

<Base
  title="Alertes & informations de sécurité | Edgward"
  description="Restez informé des incidents de sécurité près de chez vous avec Edgward. Alertes géolocalisées, sources vérifiées, intervention en un clic."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="hero-badge-dot" aria-hidden="true"></span>
            Nouveau dans l'application
          </div>
          <h1>Restez informé de ce qui se passe<br><em>près de chez vous</em></h1>
          <p>Des alertes de sécurité géolocalisées, vérifiées, et pertinentes — directement dans votre app. Sachez ce qui se passe dans votre quartier avant de le lire dans la presse.</p>
          <div class="hero-ctas">
            <a href="#telecharger" class="btn-primary">
              Découvrir dans l'app
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="#solution" class="btn-secondary">
              Comment ça marche
            </a>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="newsfeed-demo">
            <div class="demo-header">
              <span class="demo-title">Alertes · Votre quartier</span>
              <span class="demo-radius">1 km</span>
            </div>
            <div class="demo-item demo-item--red">
              <div class="demo-dot demo-dot--red"></div>
              <div class="demo-content">
                <strong>Cambriolage signalé</strong>
                <span>Chemin des Acacias · il y a 45 min</span>
              </div>
              <button class="demo-cta">Intervenir</button>
            </div>
            <div class="demo-item demo-item--orange">
              <div class="demo-dot demo-dot--orange"></div>
              <div class="demo-content">
                <strong>Véhicule suspect</strong>
                <span>Route de Chêne · il y a 2h</span>
              </div>
            </div>
            <div class="demo-item demo-item--yellow">
              <div class="demo-dot demo-dot--yellow"></div>
              <div class="demo-content">
                <strong>Tentative d'intrusion</strong>
                <span>Rue du Marché · il y a 4h</span>
              </div>
            </div>
            <div class="demo-item">
              <div class="demo-dot demo-dot--green"></div>
              <div class="demo-content">
                <strong>Intervention terminée ✓</strong>
                <span>Bd des Promenades · il y a 6h</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="section problem-section" id="probleme">
    <div class="container">
      <SectionHeader
        eyebrow="Le problème"
        title="L'information sécurité locale, <em>c'est opaque</em>"
        subtitle="Aujourd'hui, vous n'avez aucun moyen simple de savoir ce qui se passe dans votre quartier."
      />
      <BenefitsGrid benefits={problems} cols={3} />
    </div>
  </section>

  <!-- SOLUTION -->
  <section class="section solution-section" id="solution">
    <div class="container">
      <SectionHeader
        eyebrow="Notre solution"
        title="Un fil d'alertes <em>intelligent et local</em>"
        subtitle="Edgward agrège et filtre les signalements de sécurité pour vous donner une vision claire de votre environnement immédiat."
      />
      <BenefitsGrid benefits={solution} cols={3} />
    </div>
  </section>

  <!-- USE CASES -->
  <section class="section usecases-section" id="usages">
    <div class="container">
      <SectionHeader
        eyebrow="Cas d'usage"
        title="Quand les alertes vous <em>sont utiles</em>"
      />
      <BenefitsGrid benefits={useCases} cols={3} />
    </div>
  </section>

  <!-- PRIVACY -->
  <section class="section privacy-section" id="confidentialite">
    <div class="container">
      <div class="privacy-block fade-in">
        <div class="privacy-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="privacy-content">
          <h3>Vos données restent les vôtres</h3>
          <p>Les alertes du fil sont anonymisées : aucun utilisateur ne peut voir qui a signalé quoi. Votre localisation n'est jamais partagée avec d'autres utilisateurs ou partenaires. Toutes les données sont traitées conformément au RGPD et à la Loi fédérale suisse sur la protection des données (LPD). <a href="/confidentialite">Lire notre politique de confidentialité →</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <FinalCTA
    title="Découvrez les alertes dans <em>l'application</em>"
    description="Téléchargez Edgward et activez les alertes de votre quartier dès aujourd'hui."
    appStoreUrl="https://apps.apple.com/ch/app/edgward/id6503622410"
    playStoreUrl="https://play.google.com/store/apps/details?id=ch.edgward.app.clients"
  />
</Base>

<style>
  .hero { background: var(--navy); color: white; padding: 72px 0 56px; overflow: hidden; position: relative; }
  .hero::before { content: ''; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center; position: relative; z-index: 2; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-soft); color: var(--brand-light); padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); margin-bottom: 22px; }
  .hero-badge-dot { width: 7px; height: 7px; background: var(--brand-light); border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.2); } }
  .hero h1 { font-size: clamp(36px, 4.5vw, 54px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero-content > p { font-size: 17px; line-height: 1.6; color: #cbd5e1; margin-bottom: 30px; max-width: 520px; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary { background: var(--brand); color: white; padding: 14px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border: none; cursor: pointer; transition: all 0.2s ease; font-family: inherit; }
  .btn-primary:hover { background: var(--brand-dark); transform: translateY(-2px); }
  .btn-secondary { background: transparent; color: white; padding: 14px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.25); cursor: pointer; transition: all 0.2s ease; }
  .btn-secondary:hover { background: rgba(255,255,255,0.08); }

  /* NEWSFEED DEMO */
  .hero-visual { display: flex; align-items: center; justify-content: center; min-height: 380px; }
  .newsfeed-demo { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: var(--radius-lg); padding: 20px; width: 100%; max-width: 360px; display: flex; flex-direction: column; gap: 10px; }
  .demo-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
  .demo-title { font-size: 13px; font-weight: 600; color: white; }
  .demo-radius { font-size: 11px; color: var(--brand-light); background: var(--brand-soft); padding: 2px 8px; border-radius: 100px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); }
  .demo-item { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.04); border-radius: 8px; padding: 10px 12px; border: 1px solid rgba(255,255,255,0.06); }
  .demo-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .demo-dot--red { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.6); }
  .demo-dot--orange { background: #f97316; box-shadow: 0 0 6px rgba(249,115,22,0.6); }
  .demo-dot--yellow { background: #eab308; }
  .demo-dot--green { background: #22c55e; }
  .demo-content { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .demo-content strong { font-size: 12px; color: white; font-weight: 600; }
  .demo-content span { font-size: 10px; color: #94a3b8; }
  .demo-cta { background: var(--brand); color: white; border: none; border-radius: 6px; font-size: 11px; font-weight: 600; padding: 4px 10px; cursor: pointer; font-family: inherit; white-space: nowrap; transition: background 0.2s ease; }
  .demo-cta:hover { background: var(--brand-dark); }

  .problem-section { background: white; }
  .solution-section { background: var(--soft); }
  .usecases-section { background: white; }

  /* PRIVACY */
  .privacy-section { background: var(--soft); }
  .privacy-block { display: flex; align-items: flex-start; gap: 24px; background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px; max-width: 680px; margin: 0 auto; }
  .privacy-icon { width: 56px; height: 56px; background: var(--brand-soft); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: var(--brand); flex-shrink: 0; }
  .privacy-content h3 { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .privacy-content p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }
  .privacy-content a { color: var(--brand); text-decoration: none; font-weight: 600; }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { order: -1; }
  }
  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
    .privacy-block { flex-direction: column; text-align: center; }
    .privacy-icon { margin: 0 auto; }
  }
</style>
