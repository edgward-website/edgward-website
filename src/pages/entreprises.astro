---
import Base from '../layouts/Base.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import PricingCard from '../components/PricingCard.astro';
import Testimonials from '../components/Testimonials.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EdSonar from '../components/EdSonar.astro';

const useCases = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>',
    title: 'Commerces & boutiques',
    description: "Protégez vos locaux commerciaux, stocks et caisses. Intervention rapide en cas de tentative d'intrusion ou de situation suspecte.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 14l4-4 4 4M12 18V10M6 21h12a2 2 0 002-2V7l-5-5H6a2 2 0 00-2 2v15a2 2 0 002 2z"/></svg>',
    title: 'Chantiers',
    description: "Vols de matériaux, vandalisme, intrusions nocturnes — surveillez vos chantiers sans installation permanente.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'Bureaux & espaces pros',
    description: "Sécurisez vos espaces professionnels, serveurs et données sensibles. Rondes sur mesure adaptées à vos horaires.",
  },
];

const benefits = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>',
    title: 'Gestion multi-sites',
    description: 'Centralisez la sécurité de tous vos sites depuis une seule interface.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>',
    title: 'Facturation consolidée',
    description: 'Une facture mensuelle unique pour l\'ensemble de vos sites et interventions.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
    title: "Reporting d'interventions",
    description: "Tableau de bord avec historique complet, rapports et statistiques de sécurité par site.",
  },
];

const testimonials = [
  {
    quote: "Des inconnus dans notre garage de Belmont. L'agent est intervenu rapidement. Plus avantageux qu'un raccordement d'alarme classique.",
    name: 'Mike K.',
    role: 'Garage mécanique · Belmont (VD)',
    initials: 'MK',
  },
];

const priceRows = [
  { label: 'Abonnement mensuel (par site)', value: 'CHF 29/mois' },
  { label: 'Intervention standard', value: '~CHF 60' },
  { label: 'Intervention urgente', value: '~CHF 95' },
];
---

<Base
  title="Entreprises — Sécurité professionnelle à la demande | Edgward"
  description="Protégez locaux, chantiers et commerces avec Edgward. Multi-sites, facturation consolidée, reporting d'interventions. Alternative flexible à la télésurveillance classique."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="hero-eyebrow">Entreprises & Centrales d'alarme</span>
          <h1>La sécurité professionnelle,<br><em>sans les contraintes</em></h1>
          <p>Multi-sites, facturation consolidée, intégration technique. Conçu pour les PME, grandes entreprises et centrales d'alarme.</p>
          <div class="hero-ctas">
            <a href="#contact" class="btn-primary">
              Demander un devis
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="#avantages" class="btn-secondary">En savoir plus</a>
          </div>
          <p class="hero-reassurance">Sans installation · Sans engagement long terme · Dès CHF 29/mois par site</p>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <EdSonar image="/assets/ed-pose.png" />
        </div>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="section" id="usages">
    <div class="container">
      <SectionHeader
        eyebrow="Cas d'usage"
        title="Trois situations où Edgward <em>fait la différence</em>"
        subtitle="Commerce, chantier, bureau — une solution unique pour tous vos besoins de sécurité."
      />
      <BenefitsGrid benefits={useCases} cols={3} />
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="section benefits-section" id="avantages">
    <div class="container">
      <SectionHeader
        eyebrow="Fonctionnalités"
        title="Conçu pour les <em>professionnels</em>"
        subtitle="Des outils pensés pour simplifier la gestion sécurité multi-sites."
      />
      <BenefitsGrid benefits={benefits} cols={3} />
    </div>
  </section>

  <!-- PRICING -->
  <section class="section pricing-section" id="tarifs">
    <div class="container">
      <SectionHeader
        eyebrow="Tarification"
        title="Un investissement <em>raisonnable</em>"
        subtitle="Abonnement par site + interventions réellement déclenchées. Zéro surprise."
      />
      <PricingCard
        headline="Moins cher qu'une télésurveillance classique, plus flexible"
        description="Pas d'installation coûteuse, pas d'engagement sur 3 ans. Vous payez uniquement ce que vous utilisez."
        ctaLabel="Demander un devis personnalisé"
        ctaHref="#contact"
        priceRows={priceRows}
        highlight={{ label: 'Économie vs. télésurveillance', value: '→ 3× moins cher' }}
      />
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="section testimonials-section">
    <div class="container">
      <SectionHeader
        eyebrow="Témoignages"
        title="Ce que disent nos <em>clients professionnels</em>"
      />
      <Testimonials items={testimonials} />
    </div>
  </section>

  <!-- CENTRALES D'ALARME -->
  <section class="section centrales-section" id="centrales">
    <div class="container">
      <div class="centrale-block fade-in">
        <div class="centrale-content">
          <span class="eyebrow">Centrales d'alarme</span>
          <h2>Déléguez vos levées de doute <em>en un email</em></h2>
          <p>Intégration par email structuré : dispatchez un agent Edgward depuis votre plateforme existante, sans surcoût logiciel ni développement spécifique.</p>
          <ul class="centrale-features">
            <li>Intégration sans développement supplémentaire</li>
            <li>Couverture complète de la Suisse romande</li>
            <li>Facturation à l'intervention</li>
            <li>Rapport d'intervention automatique</li>
          </ul>
          <a href="#contact" class="btn-primary">
            Découvrir l'intégration
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="centrale-visual">
          <div class="email-demo">
            <div class="email-demo-header">
              <div class="email-demo-dot"></div>
              <div class="email-demo-dot"></div>
              <div class="email-demo-dot"></div>
            </div>
            <div class="email-demo-body">
              <div class="email-line"><strong>De :</strong> centrale@securite.ch</div>
              <div class="email-line"><strong>À :</strong> dispatch@edgward.ch</div>
              <div class="email-line email-subject"><strong>Objet :</strong> LEVÉE DE DOUTE — Alarme Zone A</div>
              <div class="email-content">
                <div class="email-badge">Dispatché ✓</div>
                <p>Agent assigné · ETA 12 min</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-section" id="contact">
    <div class="container">
      <SectionHeader
        eyebrow="Contact"
        title="Parlons de votre <em>besoin</em>"
        subtitle="Notre équipe vous répond sous 24h avec une offre personnalisée."
      />
      <ContactForm defaultSubject="Entreprise" />
    </div>
  </section>
</Base>

<style>
  .hero { background: var(--navy); color: white; padding: 72px 0 56px; overflow: hidden; position: relative; }
  .hero::before { content: ''; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .hero-grid { display: grid; grid-template-columns: 1.25fr 1fr; gap: 48px; align-items: center; position: relative; z-index: 2; }
  .hero-eyebrow { display: inline-block; font-size: 12px; color: var(--brand-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; opacity: 0.8; }
  .hero h1 { font-size: clamp(36px, 4.5vw, 54px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero-content > p { font-size: 17px; line-height: 1.6; color: #cbd5e1; margin-bottom: 30px; max-width: 520px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
  .hero-reassurance { font-size: 13px; color: #94a3b8; }
  .hero-visual { position: relative; display: flex; align-items: center; justify-content: center; min-height: 400px; }
  .btn-primary { background: var(--brand); color: white; padding: 14px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border: none; cursor: pointer; transition: all 0.2s ease; font-family: inherit; box-shadow: 0 1px 3px rgba(70,120,220,0.3); }
  .btn-primary:hover { background: var(--brand-dark); transform: translateY(-2px); }
  .btn-secondary { background: transparent; color: white; padding: 14px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.25); cursor: pointer; transition: all 0.2s ease; }
  .btn-secondary:hover { background: rgba(255,255,255,0.08); }
  .benefits-section { background: var(--soft); }
  .pricing-section { background: var(--soft); }
  .testimonials-section { background: white; }
  .centrales-section { background: var(--navy); }
  .centrale-block { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; color: white; }
  .eyebrow { display: inline-block; font-size: 12px; color: var(--brand-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 12px; }
  .centrale-content h2 { font-size: clamp(26px, 3vw, 36px); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px; }
  .centrale-content h2 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .centrale-content p { font-size: 15px; color: #cbd5e1; line-height: 1.6; margin-bottom: 20px; }
  .centrale-features { list-style: none; margin-bottom: 28px; display: flex; flex-direction: column; gap: 10px; }
  .centrale-features li { font-size: 14px; color: #cbd5e1; padding-left: 22px; position: relative; }
  .centrale-features li::before { content: ''; position: absolute; left: 0; top: 6px; width: 12px; height: 6px; border-left: 2px solid var(--brand-light); border-bottom: 2px solid var(--brand-light); transform: rotate(-45deg); }
  .email-demo { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: var(--radius-lg); padding: 24px; }
  .email-demo-header { display: flex; gap: 6px; margin-bottom: 16px; }
  .email-demo-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.2); }
  .email-demo-body { display: flex; flex-direction: column; gap: 8px; }
  .email-line { font-size: 12px; color: #94a3b8; font-family: monospace; }
  .email-line strong { color: #cbd5e1; }
  .email-subject { color: white; }
  .email-content { margin-top: 12px; padding: 12px; background: rgba(70,120,220,0.15); border-radius: 8px; border: 1px solid rgba(70,120,220,0.3); }
  .email-badge { display: inline-block; background: var(--brand); color: white; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 100px; margin-bottom: 6px; }
  .email-content p { font-size: 12px; color: #94a3b8; margin: 0; }
  .contact-section { background: white; }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { min-height: 340px; order: -1; }
    .centrale-block { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
  }
</style>
