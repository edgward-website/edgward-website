---
import Base from '../layouts/Base.astro';
---

<Base
  title="Entreprises — Edgward, sécurité à la demande pour professionnels"
  description="Protégez vos locaux, chantiers et commerces avec Edgward. Multi-sites, facturation consolidée, reporting d'interventions. Alternatiive flexible à la télésurveillance."
>
  <section class="page-hero">
    <div class="container">
      <span class="section-eyebrow">Entreprises & Centrales d'alarme</span>
      <h1>La sécurité professionnelle,<br><em>sans les contraintes</em></h1>
      <p class="page-hero-sub">Multi-sites, facturation consolidée, intégration technique. Conçu pour les PME, grandes entreprises et centrales d'alarme.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="placeholder-content">
        <p>Contenu de la page entreprises à venir.</p>
        <a href="/" class="btn-ghost">← Retour à l'accueil</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { background: var(--navy); color: white; padding: 80px 0 72px; text-align: center; }
  .page-hero h1 { font-size: clamp(32px, 4vw, 52px); font-weight: 800; line-height: 1.1; letter-spacing: -0.025em; color: white; margin: 12px 0 20px; }
  .page-hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .page-hero-sub { font-size: 17px; color: #cbd5e1; max-width: 560px; margin: 0 auto; line-height: 1.6; }
  .placeholder-content { text-align: center; padding: 48px; background: var(--soft); border-radius: var(--radius-lg); border: 2px dashed var(--border); display: flex; flex-direction: column; align-items: center; gap: 24px; color: var(--text-muted); font-size: 15px; }
</style>
