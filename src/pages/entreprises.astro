---
import Base from '../layouts/Base.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import PricingCard from '../components/PricingCard.astro';
import Testimonials from '../components/Testimonials.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EdSonar from '../components/EdSonar.astro';

const useCases = [
  {
    eyebrow: 'Commerce de détail',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>',
    title: 'Fermeture tardive, colis livré — agent requis',
    description: "Gérez les situations imprévues sans coût fixe : vérification nocturne, levée d'alarme, présence rassurante.",
  },
  {
    eyebrow: 'Chantier',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 18h19"/><path d="M4 18v-1.5a8 8 0 0116 0V18"/><path d="M10 8.2V4.5a1 1 0 011-1h2a1 1 0 011 1v3.7"/><path d="M14 4.7a6.5 6.5 0 014 5.3M10 4.7a6.5 6.5 0 00-4 5.3"/></svg>',
    title: 'Surveillance nocturne sans gardien permanent',
    description: "Matériel et équipement protégés la nuit. Intervention rapide en cas d'intrusion, sans coût fixe mensuel.",
  },
  {
    eyebrow: 'Bureau / PME',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'Sécurité flexible pour vos locaux',
    description: "Rondes périodiques, vérification après alarme, accueil sécurisé d'événements. Vous choisissez, vous activez.",
  },
];

const testimonials = [
  {
    quote: "Des inconnus dans notre garage de Belmont. L'agent est intervenu à deux. Plus avantageux qu'un raccordement d'alarme classique.",
    name: 'Mike K.',
    role: 'Belmont VD — Gérant de garage',
    initials: 'MK',
    stars: 5,
  },
];

const priceRows = [
  { label: 'Abonnement (base annuelle)', value: 'CHF 12.50/mois' },
  { label: 'Intervention (prix moyen par intervention)', value: '~CHF 105 - 170' },
];
---

<Base
  title="Entreprises — Sécurité professionnelle à la demande | Edgward"
  description="Protégez locaux, chantiers et commerces avec Edgward. Multi-sites, facturation consolidée, reporting d'interventions. Alternative flexible à la télésurveillance classique."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="hero-eyebrow">Entreprises & Centrales d'alarme</span>
          <h1>Commerces, locaux, chantiers<br>protégés <em>à la demande</em></h1>
          <p>Stoppez les dépenses fixes de télésurveillance. Avec Edgward, vous activez la sécurité quand vous en avez besoin, sur les sites qui le nécessitent.</p>
          <div class="hero-ctas">
            <a href="#contact" class="btn-primary">
              Demander un devis
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="#avantages" class="btn-secondary">En savoir plus</a>
          </div>
          <p class="hero-reassurance">Sans installation · Sans engagement long terme · Dès CHF 15/mois par site</p>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <EdSonar />
        </div>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="section" id="usages">
    <div class="container">
      <SectionHeader
        eyebrow="Cas d'usage"
        title="Trois situations où Edgward <em>fait la différence </em>"
        subtitle="Commerce, chantier, bureau — une solution unique pour tous vos besoins de sécurité."
      />
      <BenefitsGrid benefits={useCases} cols={3} />
    </div>
  </section>

  <!-- PRICING -->
  <section class="section pricing-section" id="tarifs">
    <div class="container">
      <SectionHeader
        eyebrow="Tarification"
        title="Un investissement <em>raisonnable</em>"
        subtitle="Abonnement par site + interventions réellement déclenchées. Zéro surprise."
      />
      <PricingCard
        headline="Tarification sur devis selon volume"
        description="Pas d'installation à 2 000–6 000 CHF comme la télésurveillance classique. Pas d'engagement longue durée. Vous payez l'abonnement plateforme + les interventions déclenchées."
        ctaLabel="Demander un devis"
        ctaHref="#contact"
        priceRows={priceRows}
        highlight={{ label: 'Économie vs. télésurveillance', value: '2 000–6 000 CHF' }}
      />
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="section testimonials-section">
    <div class="container">
      <SectionHeader
        eyebrow="Témoignages"
        title="Ce que disent nos <em>clients professionnels</em>"
      />
      <Testimonials items={testimonials} />
    </div>
  </section>

