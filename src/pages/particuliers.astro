---
import Base from '../layouts/Base.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import Testimonials from '../components/Testimonials.astro';
import FinalCTA from '../components/FinalCTA.astro';
import TrustBar from '../components/TrustBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EdSonar from '../components/EdSonar.astro';

const benefits = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>',
    title: 'Protégez votre domicile',
    description: "Un agent de sécurité chez vous en moins de 20 minutes sur simple demande depuis l'application.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    title: 'Disponible 24h/24, 7j/7',
    description: 'Jour, nuit, weekend ou jour férié — le réseau Edgward est toujours actif pour répondre à votre appel.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    title: 'Agents certifiés',
    description: 'Tous nos partenaires sont des entreprises de sécurité agréées, soumises à la réglementation suisse.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>',
    title: 'Rapport d\'intervention',
    description: 'À la fin de chaque mission, vous recevez un rapport détaillé avec les constats de l\'agent.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
    title: 'Sans engagement',
    description: 'Abonnement mensuel dès CHF 15. Résiliable à tout moment, sans frais ni pénalité.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>',
    title: 'Vos données protégées',
    description: 'Vos informations ne sont partagées qu\'au moment de l\'intervention, uniquement avec l\'agent mandaté.',
  },
];

const services = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>',
    title: 'Levée de doute',
    description: 'Un bruit suspect, une alarme déclenchée ? Un agent se déplace pour vérifier et vous informer.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
    title: 'Surveillance ponctuelle',
    description: 'Partez en vacances l\'esprit tranquille : planifiez des rondes pendant votre absence.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>',
    title: 'Assistance à distance',
    description: 'Guidez l\'agent en temps réel depuis l\'app pour une intervention précise et efficace.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>',
    title: 'Rapport complet',
    description: 'Chaque intervention donne lieu à un rapport détaillé consultable depuis l\'application.',
  },
];

const testimonials = [
  {
    quote: "Intervention très rapide, l'agent m'a appelée une fois sur place pour me rassurer. Le sérieux d'une vraie entreprise de sécurité, la simplicité d'une app.",
    name: 'Hélène T.',
    role: 'Particulière · Cologny (GE)',
    initials: 'HT',
  },
  {
    quote: "J'ai eu peur qu'il soit arrivé quelque chose à mon chien, j'ai demandé une intervention. Plus de peur que de mal, l'agent a été rapide et rassurant.",
    name: 'Sandy C.',
    role: 'Particulière · Carouge (GE)',
    initials: 'SC',
  },
  {
    quote: 'Depuis que je suis abonné, je pars en déplacement professionnel bien plus serein. Ma femme peut déclencher une intervention en deux clics si besoin.',
    name: 'Laurent M.',
    role: 'Particulier · Nyon (VD)',
    initials: 'LM',
  },
];
---

<Base
  title="Particuliers — Sécurité à domicile à la demande | Edgward"
  description="Protégez votre domicile et vos proches avec Edgward. Un agent de sécurité certifié chez vous en moins de 20 minutes, 24h/24. Dès CHF 15/mois, sans engagement."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="hero-badge-dot" aria-hidden="true"></span>
            Disponible dans toute la Suisse romande
          </div>
          <h1>Votre sécurité à domicile,<br><em>en un clic</em>.</h1>
          <p>Un doute, une inquiétude, une urgence ? Commandez l'intervention d'un agent près de chez vous en quelques secondes. Sans installation, sans engagement.</p>
          <div class="hero-ctas">
            <a href="#telecharger" class="btn-primary">
              Télécharger l'application
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="#comment-ca-marche" class="btn-secondary">
              Comment ça marche
            </a>
          </div>
          <p class="hero-reassurance">1 mois d'essai gratuit · Résiliable à tout moment · Dès CHF 15/mois</p>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <EdSonar />
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <TrustBar />

  <!-- BENEFITS -->
  <section class="section" id="avantages">
    <div class="container">
      <SectionHeader
        eyebrow="Pourquoi Edgward"
        title="La sécurité qui s'adapte à <em>votre vie</em>"
        subtitle="Pas d'installation. Pas d'engagement. Juste un réseau d'agents professionnels disponibles à la demande."
      />
      <BenefitsGrid benefits={benefits} cols={3} />
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section services-section" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="Nos services"
        title="Ce qu'un agent Edgward peut faire <em>pour vous</em>"
      />
      <BenefitsGrid benefits={services} cols={2} />
    </div>
  </section>

  <!-- ALERT TOOL CTA -->
  <section class="section alert-section" id="newsfeed">
    <div class="container">
      <div class="alert-block fade-in">
        <div class="alert-content">
          <span class="alert-eyebrow">Nouveau</span>
          <h2>Le fil d'alerte de <em>votre quartier</em></h2>
          <p>Restez informé des incidents signalés près de chez vous grâce au newsfeed Edgward. Une veille communautaire pour mieux anticiper les risques.</p>
          <a href="/newsfeed" class="btn-primary">
            Découvrir le newsfeed
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="alert-visual" aria-hidden="true">
          <div class="alert-mockup">
            <div class="alert-item">
              <div class="alert-dot alert-dot--orange"></div>
              <div class="alert-text">
                <strong>Cambriolage signalé</strong>
                <span>Chemin des Acacias · il y a 2h</span>
              </div>
            </div>
            <div class="alert-item">
              <div class="alert-dot alert-dot--red"></div>
              <div class="alert-text">
                <strong>Véhicule suspect</strong>
                <span>Route de Chêne · il y a 4h</span>
              </div>
            </div>
            <div class="alert-item">
              <div class="alert-dot alert-dot--yellow"></div>
              <div class="alert-text">
                <strong>Tentative d'intrusion</strong>
                <span>Rue du Rhône · il y a 6h</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section testimonials-section">
    <div class="container">
      <SectionHeader
        eyebrow="Témoignages"
        title="Ils ont fait <em>confiance</em> à Edgward"
      />
      <Testimonials items={testimonials} />
    </div>
  </section>

  <!-- FINAL CTA -->
  <FinalCTA
    title="Prêt à sécuriser<br>votre <em>domicile</em> ?"
    description="Téléchargez l'application et testez gratuitement pendant 1 mois. Résiliable à tout moment, sans frais."
  />
</Base>

<style>
  /* HERO */
  .hero { background: var(--navy); color: white; padding: 72px 0 56px; overflow: hidden; position: relative; }
  .hero::before { content: ''; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .hero-grid { display: grid; grid-template-columns: 1.25fr 1fr; gap: 48px; align-items: center; position: relative; z-index: 2; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-soft); color: var(--brand-light); padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); margin-bottom: 22px; }
  .hero-badge-dot { width: 7px; height: 7px; background: var(--brand-light); border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.2); } }
  .hero h1 { font-size: clamp(38px, 5vw, 58px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero-content > p { font-size: 17px; line-height: 1.6; color: #cbd5e1; margin-bottom: 30px; max-width: 520px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
  .hero-reassurance { font-size: 13px; color: #94a3b8; }
  .hero-visual { position: relative; display: flex; align-items: center; justify-content: center; min-height: 440px; }
  .btn-primary { background: var(--brand); color: white; padding: 14px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border: none; cursor: pointer; transition: all 0.2s ease; font-family: inherit; box-shadow: 0 1px 3px rgba(70,120,220,0.3); }
  .btn-primary:hover { background: var(--brand-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(70,120,220,0.4); }
  .btn-secondary { background: transparent; color: white; padding: 14px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.25); cursor: pointer; transition: all 0.2s ease; }
  .btn-secondary:hover { background: rgba(255,255,255,0.08); }

  /* SERVICES */
  .services-section { background: var(--soft); }

  /* ALERT SECTION */
  .alert-section { background: white; }
  .alert-block { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; background: var(--navy); border-radius: var(--radius-lg); padding: 48px; position: relative; overflow: hidden; }
  .alert-block::before { content: ''; position: absolute; top: -50%; right: -10%; width: 400px; height: 400px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .alert-content { position: relative; z-index: 1; color: white; }
  .alert-eyebrow { display: inline-block; font-size: 11px; color: var(--brand-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 12px; background: var(--brand-soft); padding: 4px 10px; border-radius: 100px; border: 1px solid rgba(70,120,220,0.3); }
  .alert-content h2 { font-size: clamp(24px, 2.5vw, 34px); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 14px; }
  .alert-content h2 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .alert-content p { font-size: 15px; color: #cbd5e1; line-height: 1.6; margin-bottom: 24px; }
  .alert-visual { position: relative; z-index: 1; }
  .alert-mockup { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius); padding: 16px; display: flex; flex-direction: column; gap: 12px; }
  .alert-item { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.04); border-radius: 8px; padding: 12px; }
  .alert-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .alert-dot--red { background: #ef4444; box-shadow: 0 0 8px rgba(239,68,68,0.5); }
  .alert-dot--orange { background: #f97316; box-shadow: 0 0 8px rgba(249,115,22,0.5); }
  .alert-dot--yellow { background: #eab308; box-shadow: 0 0 8px rgba(234,179,8,0.5); }
  .alert-text { display: flex; flex-direction: column; gap: 2px; }
  .alert-text strong { font-size: 13px; color: white; font-weight: 600; }
  .alert-text span { font-size: 11px; color: #94a3b8; }

  /* TESTIMONIALS */
  .testimonials-section { background: var(--soft); }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { min-height: 360px; order: -1; }
    .alert-block { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
  }
</style>
