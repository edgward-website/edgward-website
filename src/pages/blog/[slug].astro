---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { readingTime } from '../../utils/reading-time';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-CH', { day: 'numeric', month: 'long', year: 'numeric' });
}

// Get other posts for related section
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id)
  .slice(0, 2);

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  ...(post.data.image ? { image: new URL(post.data.image, site.url).toString() } : {}),
  publisher: {
    '@type': 'Organization',
    name: site.name,
    logo: { '@type': 'ImageObject', url: new URL('/assets/og-default.png', site.url).toString() },
  },
  mainEntityOfPage: new URL(`/blog/${post.id}/`, site.url).toString(),
};
---

<Base
  title={`${post.data.title} | Edgward Blog`}
  description={post.data.description}
  ogImage={post.data.image}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} is:inline />

  <!-- ARTICLE HERO -->
  <section class="article-hero">
    <div class="container">
      <div class="article-hero-inner">
        <div class="article-meta">
          <a href="/blog" class="back-link">← Blog</a>
          <span class="article-category">{post.data.category}</span>
        </div>
        <h1>{post.data.title}</h1>
        <div class="article-byline">
          <span>Par {post.data.author}</span>
          <span class="byline-sep">·</span>
          <time>{formatDate(post.data.date)}</time>
          {post.body && <>
            <span class="byline-sep">·</span>
            <span>{readingTime(post.body)}</span>
          </>}
        </div>
        <p class="article-description">{post.data.description}</p>
      </div>
    </div>
  </section>

  {post.data.image && (
    <div class="article-cover">
      <div class="container">
        <img src={post.data.image} alt={post.data.title} class="cover-img" loading="eager">
      </div>
    </div>
  )}

  <!-- ARTICLE BODY -->
  <article class="article-body">
    <div class="container">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>

  <!-- RELATED POSTS -->
  {relatedPosts.length > 0 && (
    <section class="related-section">
      <div class="container">
        <h2 class="related-title">Autres articles</h2>
        <div class="related-grid">
          {relatedPosts.map(related => (
            <article class="related-card">
              <span class="related-category">{related.data.category}</span>
              <h3><a href={`/blog/${related.id}`}>{related.data.title}</a></h3>
              <p>{related.data.description}</p>
              <a href={`/blog/${related.id}`} class="related-link">Lire →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- BACK -->
  <section class="back-section">
    <div class="container">
      <a href="/blog" class="btn-ghost-nav">← Retour au blog</a>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .article-hero {
    background: var(--navy); color: white;
    padding: 56px 0 48px;
  }
  .article-hero-inner { max-width: 720px; margin: 0 auto; }
  .article-meta {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 20px;
  }
  .back-link {
    font-size: 13px; color: #94a3b8;
    text-decoration: none; font-weight: 500;
    transition: color 0.15s ease;
  }
  .back-link:hover { color: var(--brand-light); }
  .article-category {
    font-size: 11px; font-weight: 700;
    color: var(--brand-light); text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--brand-soft);
    padding: 3px 10px; border-radius: 100px;
    border: 1px solid rgba(70,120,220,0.3);
  }
  .article-hero h1 {
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 800; line-height: 1.15;
    letter-spacing: -0.025em; margin-bottom: 16px; color: white;
  }
  .article-byline {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: #94a3b8; margin-bottom: 16px;
  }
  .byline-sep { opacity: 0.4; }
  .article-description {
    font-size: 16px; color: #cbd5e1; line-height: 1.6;
    border-left: 3px solid var(--brand);
    padding-left: 16px; margin: 0;
  }

  .article-cover { background: var(--soft); padding: 0; }
  .article-cover .container { padding-top: 0; padding-bottom: 0; }
  .cover-img {
    width: 100%; aspect-ratio: 1200 / 460; max-height: 460px; object-fit: cover;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  /* PROSE */
  .article-body { background: white; padding: 64px 0; }
  .prose {
    max-width: 680px; margin: 0 auto;
    font-size: 16px; line-height: 1.8; color: var(--text);
  }
  .prose :global(h2) {
    font-size: 24px; font-weight: 700; color: var(--navy);
    margin: 40px 0 14px; letter-spacing: -0.02em;
  }
  .prose :global(h3) {
    font-size: 19px; font-weight: 700; color: var(--navy);
    margin: 32px 0 10px;
  }
  .prose :global(p) { margin-bottom: 18px; color: var(--text-muted); }
  .prose :global(ul), .prose :global(ol) {
    margin: 16px 0 20px 20px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .prose :global(li) { color: var(--text-muted); }
  .prose :global(a) { color: var(--brand); text-decoration: none; font-weight: 500; }
  .prose :global(a:hover) { text-decoration: underline; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--brand);
    padding: 16px 20px;
    background: var(--soft);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin: 24px 0;
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic; font-size: 18px; color: var(--navy);
  }
  .prose :global(hr) {
    border: none; border-top: 1px solid var(--border);
    margin: 40px 0;
  }
  .prose :global(strong) { color: var(--navy); font-weight: 700; }

  /* RELATED */
  .related-section { background: var(--soft); padding: 64px 0; }
  .related-title {
    font-size: 22px; font-weight: 700; color: var(--navy);
    margin-bottom: 24px; letter-spacing: -0.02em;
    max-width: 680px; margin-left: auto; margin-right: auto;
  }
  .related-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 20px; max-width: 680px; margin: 0 auto;
  }
  .related-card {
    background: white; border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px;
    display: flex; flex-direction: column; gap: 8px;
    transition: all 0.2s ease;
  }
  .related-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
  .related-category { font-size: 11px; font-weight: 700; color: var(--brand); text-transform: uppercase; letter-spacing: 0.08em; }
  .related-card h3 { font-size: 16px; font-weight: 700; color: var(--navy); line-height: 1.3; }
  .related-card h3 a { text-decoration: none; color: inherit; }
  .related-card h3 a:hover { color: var(--brand); }
  .related-card p { font-size: 13px; color: var(--text-muted); line-height: 1.5; flex: 1; }
  .related-link { font-size: 13px; font-weight: 600; color: var(--brand); text-decoration: none; }

  .back-section { background: white; padding: 32px 0; }
  .btn-ghost-nav {
    font-size: 14px; font-weight: 600;
    color: var(--navy); text-decoration: none;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 20px; border-radius: 8px;
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }
  .btn-ghost-nav:hover { background: var(--soft); border-color: var(--navy); }

  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
