---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import SectionHeader from '../../components/SectionHeader.astro';
import { readingTime } from '../../utils/reading-time';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// « À la une » : les articles featured les plus récents (max 3).
// Le reste (y compris les featured non retenus) reste dans la grille par date.
const FEATURED_LIMIT = 3;
const featuredPosts = posts.filter(p => p.data.featured).slice(0, FEATURED_LIMIT);
const featuredIds = new Set(featuredPosts.map(p => p.id));
const restPosts = posts.filter(p => !featuredIds.has(p.id));
const categories = [...new Set(restPosts.map(p => p.data.category))].sort();

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-CH', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title="Blog - Conseils sécurité et actualités Edgward"
  description="Découvrez nos conseils sécurité, actualités et guides pratiques pour protéger votre domicile, votre entreprise ou votre commune."
>
  <PageHero
    eyebrow="Blog"
    title="Conseils, actualités <em>et guides</em>"
    subtitle="Tout ce qu'il faut savoir pour mieux protéger votre domicile, votre entreprise ou votre commune."
    maxWidth="560px"
  />

  {featuredPosts.length > 0 && (
    <section class="section featured-section">
      <div class="container">
        <h2 class="featured-heading">À la une</h2>
        <div class="featured-grid">
          {featuredPosts.map(post => (
            <article class={`featured-card fade-in${post.data.image ? '' : ' featured-card--no-image'}`}>
              {post.data.image && (
                <a href={`/blog/${post.id}`} class="featured-image">
                  <img src={post.data.image} alt={post.data.title} loading="eager">
                </a>
              )}
              <div class="featured-body">
                <div class="post-meta">
                  <span class="post-category">{post.data.category}</span>
                  <div class="post-meta-right">
                    <time class="post-date">{formatDate(post.data.date)}</time>
                    {post.body && <span class="post-reading-time">{readingTime(post.body)}</span>}
                  </div>
                </div>
                <h3 class="featured-title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h3>
                <p class="featured-excerpt">{post.data.description}</p>
                <a href={`/blog/${post.id}`} class="post-read-more">Lire l'article →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- POSTS -->
  <section class="section blog-section">
    <div class="container">
      {categories.length > 1 && (
        <div class="category-filters" role="tablist" aria-label="Filtrer par catégorie">
          <button class="filter-btn active" data-category="all" role="tab" aria-selected="true">Tous</button>
          {categories.map(cat => (
            <button class="filter-btn" data-category={cat} role="tab" aria-selected="false">{cat}</button>
          ))}
        </div>
      )}

      {restPosts.length === 0 ? (
        <p class="empty-state">Aucun autre article pour le moment. Revenez bientôt !</p>
      ) : (
        <div class="posts-grid">
          {restPosts.map(post => (
            <article class="post-card fade-in" data-category={post.data.category}>
              {post.data.image && (
                <div class="post-image">
                  <img src={post.data.image} alt={post.data.title} loading="lazy">
                </div>
              )}
              <div class="post-body">
                <div class="post-meta">
                  <span class="post-category">{post.data.category}</span>
                  <div class="post-meta-right">
                    <time class="post-date">{formatDate(post.data.date)}</time>
                    {post.body && <span class="post-reading-time">{readingTime(post.body)}</span>}
                  </div>
                </div>
                <h2 class="post-title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="post-excerpt">{post.data.description}</p>
                <div class="post-footer">
                  <span class="post-author">Par {post.data.author}</span>
                  <a href={`/blog/${post.id}`} class="post-read-more">
                    Lire l'article →
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      const category = (btn as HTMLElement).dataset.category;
      document.querySelectorAll('.post-card').forEach(card => {
        const el = card as HTMLElement;
        const match = category === 'all' || el.dataset.category === category;
        el.hidden = !match;
      });
    });
  });
</script>

<style>
  .blog-section { background: white; }

  /* À la une */
  .featured-section { background: white; padding-bottom: 0; }
  .featured-heading {
    font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--brand); margin-bottom: 20px;
    display: flex; align-items: center; gap: 12px;
  }
  .featured-heading::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .featured-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  .featured-card {
    display: grid; grid-template-columns: 1.1fr 1fr;
    background: white; border: 2px solid var(--brand);
    border-radius: var(--radius-lg); overflow: hidden;
    transition: all 0.2s ease;
  }
  .featured-card:hover { box-shadow: 0 16px 40px rgba(70,120,220,0.15); transform: translateY(-3px); }
  .featured-card--no-image { grid-template-columns: 1fr; }
  .featured-card--no-image .featured-body { padding: 28px 32px; }
  .featured-image { display: block; overflow: hidden; background: var(--soft); aspect-ratio: 16/10; }
  .featured-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .featured-card:hover .featured-image img { transform: scale(1.03); }
  .featured-body { padding: 32px; display: flex; flex-direction: column; justify-content: center; }
  .featured-title { font-size: 24px; font-weight: 800; color: var(--navy); line-height: 1.25; letter-spacing: -0.02em; margin: 14px 0 12px; }
  .featured-title a { text-decoration: none; color: inherit; transition: color 0.15s ease; }
  .featured-title a:hover { color: var(--brand); }
  .featured-excerpt { font-size: 15px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; }

  @media (max-width: 768px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-body { padding: 24px; }
    .featured-title { font-size: 20px; }
  }

  .category-filters {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .filter-btn {
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border: 1px solid var(--border);
    background: white;
    color: var(--text-muted);
    transition: all 0.15s ease;
  }
  .filter-btn:hover { border-color: var(--brand); color: var(--brand); }
  .filter-btn.active {
    background: var(--brand);
    color: white;
    border-color: var(--brand);
  }
  .post-card[hidden] { display: none; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .post-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }

  .post-image { aspect-ratio: 16/9; overflow: hidden; background: var(--soft); }
  .post-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .post-card:hover .post-image img { transform: scale(1.03); }

  .post-body { padding: 24px; display: flex; flex-direction: column; flex: 1; }

  .post-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .post-category {
    font-size: 11px; font-weight: 700;
    color: var(--brand); text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--brand-soft);
    padding: 3px 10px; border-radius: 100px;
  }
  .post-meta-right { display: flex; align-items: center; gap: 8px; }
  .post-date { font-size: 12px; color: var(--text-light); }
  .post-reading-time { font-size: 11px; color: var(--text-light); padding-left: 8px; border-left: 1px solid var(--border); }

  .post-title { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 10px; line-height: 1.3; letter-spacing: -0.01em; }
  .post-title a { text-decoration: none; color: inherit; transition: color 0.15s ease; }
  .post-title a:hover { color: var(--brand); }

  .post-excerpt { font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; flex: 1; }

  .post-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 16px; border-top: 1px solid var(--border);
  }
  .post-author { font-size: 12px; color: var(--text-muted); }
  .post-read-more { font-size: 13px; font-weight: 600; color: var(--brand); text-decoration: none; transition: color 0.15s ease; }
  .post-read-more:hover { color: var(--brand-dark); }

  .empty-state { text-align: center; color: var(--text-muted); font-size: 16px; padding: 48px; }

  @media (max-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
