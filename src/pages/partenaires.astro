---
import Base from '../layouts/Base.astro';
import PartnerDetailCard from '../components/PartnerDetailCard.astro';
import SectionHeader from '../components/SectionHeader.astro';

const partners = [
  {
    name: 'SPS - Global Sécurité',
    zone: 'Arc lémanique',
    description: "Acteur reconnu de la sécurité humaine, Global Sécurité propose surveillance, contrôles d'accès et interventions rapides sur l'Arc lémanique. Disponible 24h/24.",
    siteUrl: 'https://global-securite.ch/',
    logo: '/assets/partners/global-securite.png',
  },
  {
    name: 'GPA SA',
    zone: 'Suisse romande',
    description: "Acteur incontournable de la sécurité en Suisse romande. Intervient 24h/24, spécialisé dans la surveillance mobile et l'intervention rapide sur l'ensemble du territoire romand.",
    siteUrl: 'https://www.gpa.ch/',
    logo: '/assets/partners/gpa.png',
  },
  {
    name: 'Python Sécurité SA',
    zone: 'Genève (20+ ans d\'expérience)',
    description: "Plus de 20 ans d'expertise à Genève. Python Sécurité offre des solutions sur mesure : surveillance de sites, intervention mobile et gestion des accès pour particuliers et entreprises.",
    siteUrl: 'https://python-securite.ch/',
    logo: '/assets/partners/python.png',
  },
  {
    name: 'Sécurice',
    zone: 'Neuchâtel',
    description: "Spécialiste de la sécurité dans le canton de Neuchâtel. Sécurice assure rondes de surveillance, intervention 24/7 et protection des biens pour les particuliers et les entreprises.",
    siteUrl: 'https://www.securice.ch/',
    logo: '/assets/partners/securice.png',
  },
  {
    name: 'Juggers',
    zone: 'Vaud',
    description: "Entreprise de sécurité active sur Genève et Vaud. Juggers intervient rapidement pour des missions de surveillance, gardiennage et sécurité événementielle.",
    siteUrl: 'https://www.juggers.ch/',
    logo: '/assets/partners/juggers.png',
  },
  {
    name: 'Alpshawk',
    zone: 'Valais',
    description: "Basée dans le canton de Vaud, Alpshawk assure des prestations de sécurité sur mesure : rondes, interventions et surveillance pour particuliers et professionnels.",
    siteUrl: 'https://www.alpshawk.ch/',
    logo: '/assets/partners/alpshawk.png',
  },
  {
    name: 'Wolfguard',
    zone: 'Vaud',
    description: "Spécialiste de la sécurité à Genève, Wolfguard propose gardiennage, rondes de surveillance et interventions rapides pour la protection des biens et des personnes.",
    siteUrl: 'https://www.wolfguard.ch/',
    logo: '/assets/partners/wolfguard.png',
  },
  {
    name: 'Roc Sécurité',
    zone: 'Valais',
    description: "Entreprise valaisanne de sécurité privée. Roc Sécurité offre des services de surveillance, d'intervention et de protection adaptés aux besoins du canton.",
    siteUrl: 'https://www.rocsecurite.ch/',
    logo: '/assets/partners/roc-securite.png',
  },
  {
    name: 'KRK Security',
    zone: 'Genève',
    description: "Active dans le canton de Fribourg, KRK Security assure gardiennage, patrouilles et interventions pour sécuriser commerces, entreprises et particuliers.",
    siteUrl: 'https://krksecurity.ch/',
    logo: '/assets/partners/krk.png',
  },
];
---

<Base
  title="Partenaires sécurité - Réseau Edgward en Suisse romande"
  description="Découvrez les 9 entreprises de sécurité partenaires d'Edgward en Suisse romande. Agréées, certifiées, disponibles 24h/24 sur Genève, Vaud et Valais."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <span class="hero-eyebrow">Réseau partenaires</span>
        <h1>Des entreprises de sécurité <em>à votre service</em></h1>
        <p>Edgward s'appuie sur un réseau sélectionné d'entreprises de sécurité agréées en Suisse romande. Toutes sont soumises aux mêmes exigences de qualité et de réactivité.</p>
      </div>
    </div>
  </section>

  <!-- PARTNERS GRID -->
  <section class="section partners-section">
    <div class="container">
      <SectionHeader
        eyebrow="Nos partenaires"
        title="Des entreprises <em>sélectionnées et certifiées</em>"
        subtitle="Chaque partenaire Edgward est audité sur ses qualifications, ses temps de réponse et la satisfaction de ses clients."
      />
      <div class="partners-grid">
        {partners.map(p => (
          <PartnerDetailCard
            name={p.name}
            zone={p.zone}
            description={p.description}
            siteUrl={p.siteUrl}
            logo={p.logo}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CRITERIA -->
  <section class="section criteria-section">
    <div class="container">
      <SectionHeader
        eyebrow="Critères de sélection"
        title="Comment nous sélectionnons <em>nos partenaires</em>"
      />
      <div class="criteria-grid">
        <div class="criterion fade-in">
          <div class="criterion-num">01</div>
          <h3>Agrément cantonal</h3>
          <p>Toutes les entreprises partenaires sont agréées par les autorités cantonales compétentes et respectent la réglementation sur les agents de sécurité privés.</p>
        </div>
        <div class="criterion fade-in">
          <div class="criterion-num">02</div>
          <h3>Temps de réponse</h3>
          <p>Chaque partenaire est évalué sur sa capacité à répondre aux demandes en moins de 20 minutes en zone urbaine. Les temps réels sont affichés dans l'application.</p>
        </div>
        <div class="criterion fade-in">
          <div class="criterion-num">03</div>
          <h3>Satisfaction clients</h3>
          <p>Chaque intervention est notée par l'utilisateur. Un score insuffisant entraîne un audit et peut conduire à la suspension du partenaire.</p>
        </div>
        <div class="criterion fade-in">
          <div class="criterion-num">04</div>
          <h3>Formation continue</h3>
          <p>Les agents doivent justifier d'une formation à jour, incluant les premiers secours, la gestion de conflits et les procédures Edgward.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA DEVENIR PARTENAIRE -->
  <section class="section become-section">
    <div class="container">
      <div class="become-block fade-in">
        <div class="become-content">
          <span class="become-eyebrow">Vous êtes une entreprise de sécurité ?</span>
          <h2>Rejoignez le réseau <em>Edgward</em></h2>
          <p>Accédez à de nouvelles sources de missions qualifiées sans investissement commercial. Notre plateforme vous connecte directement avec des clients vérifiés.</p>
          <a href="/entreprises-securite" class="btn-primary">
            Devenir partenaire
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="become-stats">
          <div class="become-stat">
            <strong>9+</strong>
            <span>partenaires actifs</span>
          </div>
          <div class="become-stat">
            <strong>240+</strong>
            <span>clients Edgward</span>
          </div>
          <div class="become-stat">
            <strong>&lt;20 min</strong>
            <span>temps moyen</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: var(--navy);
    color: white;
    padding: 80px 0 72px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
  .hero-eyebrow {
    display: inline-block;
    font-size: 12px; color: var(--brand-light);
    font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; margin-bottom: 16px;
  }
  .hero h1 {
    font-size: clamp(34px, 4.5vw, 52px);
    font-weight: 800; line-height: 1.1;
    letter-spacing: -0.025em; margin-bottom: 20px; color: white;
  }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero p { font-size: 17px; color: #cbd5e1; line-height: 1.6; max-width: 540px; margin: 0 auto; }

  .partners-section { background: white; }
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* CRITERIA */
  .criteria-section { background: var(--soft); }
  .criteria-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .criterion {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
  }
  .criterion-num {
    font-size: 13px;
    font-weight: 700;
    color: var(--brand);
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 28px;
    margin-bottom: 12px;
    line-height: 1;
  }
  .criterion h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .criterion p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

  /* BECOME */
  .become-section { background: white; }
  .become-block {
    background: var(--navy);
    border-radius: var(--radius-lg);
    padding: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    position: relative;
    overflow: hidden;
  }
  .become-block::before {
    content: '';
    position: absolute;
    top: -50%; right: -10%;
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .become-content { position: relative; z-index: 1; color: white; flex: 1; }
  .become-eyebrow {
    display: inline-block;
    font-size: 12px; color: var(--brand-light);
    font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; margin-bottom: 12px;
  }
  .become-content h2 {
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 800; line-height: 1.15;
    letter-spacing: -0.02em; margin-bottom: 14px;
    color: white;
  }
  .become-content h2 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .become-content p { font-size: 15px; color: #cbd5e1; line-height: 1.6; margin-bottom: 24px; max-width: 480px; }
  .become-stats {
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .become-stat { text-align: right; }
  .become-stat strong { display: block; font-size: 28px; font-weight: 800; color: white; letter-spacing: -0.02em; }
  .become-stat span { font-size: 12px; color: #94a3b8; }

  @media (max-width: 1024px) {
    .criteria-grid { grid-template-columns: repeat(2, 1fr); }
    .partners-grid { grid-template-columns: repeat(2, 1fr); }
    .become-block { flex-direction: column; }
    .become-stats { flex-direction: row; align-self: stretch; justify-content: space-around; }
    .become-stat { text-align: center; }
  }
  @media (max-width: 640px) {
    .partners-grid { grid-template-columns: 1fr; }
    .criteria-grid { grid-template-columns: 1fr; }
  }
</style>
