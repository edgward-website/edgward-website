---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FinalCTA from '../components/FinalCTA.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import Testimonials from '../components/Testimonials.astro';
import PartnersGrid from '../components/PartnersGrid.astro';
import Steps from '../components/Steps.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { partners } from '../data/partners';

// --- Données propres à la commune ---
const commune = "Le Locle";
const quartiers = [
  "Centre / Grande-Rue", "Le Communal", "Les Jeanneret", "Les Monts", "La Jaluse", "Le Verger", "Les Replattes", "Bellevue",
];

const neuchatelNames = ['GPA SA', 'Sécurice'];
const partenairesNE = partners.filter(p => neuchatelNames.includes(p.name));

const solution = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3"/></svg>',
    title: 'Savoir - les alertes de votre secteur',
    description: "Recevez les signalements vérifiés autour de chez vous, au Locle : cambriolages, véhicules suspects, démarchage douteux. Des signalements vérifiés et modérés, loin des rumeurs des groupes WhatsApp.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 9l4.5 11 1.7-4.8 4.8-1.7z"/><path d="M7.5 2.7 8.2 5M5 7.5 2.7 6.8M13.3 4.7 11.6 6.4M6.4 11.6 4.7 13.3"/></svg>',
    title: 'Agir - une patrouille à la demande',
    description: "Une absence prolongée, un doute au retour, une alerte dans votre rue ? Déclenchez l'intervention d'une société de sécurité partenaire neuchâteloise en quelques secondes.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>',
    title: 'Sans engagement',
    description: "Aucun contrat contraignant : les alertes de votre secteur sont gratuites, et l'intervention se paie à l'usage, uniquement quand vous la demandez.",
  },
];

const etapes = [
  { num: '1', title: "Téléchargez l'application", description: "Disponible sur iPhone et Android, Edgward s'installe en un instant ; la création du compte prend deux minutes." },
  { num: '2', title: 'Activez les alertes au Locle', description: "Renseignez votre adresse et suivez les signalements vérifiés autour de chez vous. Cette partie est 100% gratuite." },
  { num: '3', title: 'Déclenchez une intervention', description: "Si une situation vous inquiète, commandez une patrouille en quelques secondes et recevez un rapport après le passage de l'agent." },
];

const faq = [
  {
    "question": "Edgward est-il disponible au Locle ?",
    "answer": "Oui. Edgward couvre votre secteur (Centre / Grande-Rue, Le Communal, Les Jeanneret) grâce à ses sociétés de sécurité partenaires du canton, GPA et Sécurice. Vous recevez les alertes vérifiées près de chez vous et pouvez déclencher l'intervention d'une patrouille à la demande, sans abonnement de gardiennage."
  },
  {
    "question": "Faut-il s'inquiéter au Locle ?",
    "answer": "Non, mais mieux vaut rester attentif. Ville frontière nichée dans une vallée, Le Locle voit peu de passage nocturne : un soir d'hiver, une présence anormale peut passer inaperçue. Les alertes de quartier et l'intervention à la demande comblent cette distance."
  },
  {
    "question": "Combien coûte Edgward et comment l'activer au Locle ?",
    "answer": "Les alertes de votre quartier sont 100% gratuites. L'abonnement complet est à CHF 15.-/mois, et vous ne payez une intervention que si vous en commandez une. Il suffit de télécharger l'application, d'indiquer votre adresse au Locle et d'activer les alertes."
  }
];

const temoignages = [
  {
    quote: "Intervention rapide et agent très sympa, merci !",
    name: "Emmanuelle F.",
    role: "Cliente en Suisse romande",
    initials: "EF",
  },
  {
    quote: "Je n'étais pas sûr de qui traînait dans mon jardin, les agents ont été bien réactifs, top.",
    name: "Marc M.",
    role: "Client en Suisse romande",
    initials: "MM",
  },
  {
    quote: "Le module d'alertes et informations est super utile.",
    name: "Caroline M.",
    role: "Utilisatrice en Suisse romande",
    initials: "CM",
    stars: 4,
  },
];
---

<Base
  title="Sécurité au Locle : alertes et intervention à la demande | Edgward"
  description="Au Locle, suivez les alertes vérifiées de votre quartier et faites intervenir une patrouille à la demande. Sécurité sans engagement dès CHF 15.-/mois."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="hero-badge">
            <img class="canton-flag" src="/assets/flag-neuchatel.png" width="22" height="22" alt="" aria-hidden="true">
            Le Locle · Canton de Neuchâtel
          </div>
          <h1>Votre sécurité au Locle,<br><em>quartier par quartier</em></h1>
          <p>Suivez ce qui se passe réellement près de chez vous <strong>et</strong> faites intervenir une patrouille à la demande. Alertes géolocalisées vérifiées et gratuites, sans engagement.</p>
          <div class="hero-ctas">
            <a href="#comment-ca-marche" class="btn-primary">
              Comment ça marche
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="/securite-neuchatel" class="btn-secondary">
              Voir tout le canton de Neuchâtel
            </a>
          </div>
          <p class="hero-note">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Découvrez le <a href="/alertes">module Alertes &amp; Informations</a> ou nos solutions pour <a href="/entreprises">entreprises</a>.
          </p>
        </div>
        <div class="hero-visual">
          <div class="newsfeed-demo" aria-label="Exemple d'alertes au Locle">
            <div class="demo-header">
              <span class="demo-title">Alertes · {commune}</span>
              <span class="demo-radius">1 km</span>
            </div>
            <div class="demo-item demo-item--red">
              <div class="demo-dot demo-dot--red"></div>
              <div class="demo-content">
                <strong>Cambriolage d'un appartement</strong>
                <span>Les Jeanneret · il y a 35 min</span>
              </div>
              <a href="/alertes" class="demo-cta">Intervenir</a>
            </div>
            <div class="demo-item demo-item--orange">
              <div class="demo-dot demo-dot--orange"></div>
              <div class="demo-content">
                <strong>Véhicule suspect signalé</strong>
                <span>Le Communal · il y a 2h</span>
              </div>
            </div>
            <div class="demo-item demo-item--yellow">
              <div class="demo-dot demo-dot--yellow"></div>
              <div class="demo-content">
                <strong>Manifestation au centre-ville</strong>
                <span>Grande-Rue · aujourd'hui</span>
              </div>
            </div>
            <div class="demo-item">
              <div class="demo-dot demo-dot--blue"></div>
              <div class="demo-content">
                <strong>Alerte météo sur le canton</strong>
                <span>Neuchâtel · il y a 1h</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTRO LOCALE -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-prose">
        <p><strong>Ville horlogère nichée dans une vallée du Jura</strong>, Le Locle partage avec sa voisine La Chaux-de-Fonds l'inscription de son urbanisme au patrimoine mondial de l'UNESCO. Une commune compacte, cernée par les crêtes et la frontière française toute proche, où l'on se connaît mais où l'hiver et l'isolement demandent une vigilance particulière.</p>
      </div>
    </div>
  </section>

  <!-- CONTEXTE CANTONAL -->
  <section class="section figures-section" id="contexte">
    <div class="container">
      <SectionHeader
        eyebrow="Le contexte 2025"
        title="Ce que disent <em>les chiffres neuchâtelois</em>"
        subtitle="La police neuchâteloise ne publie pas de statistiques par commune, mais le bilan cantonal 2025 donne le cadre."
      />
      <div class="figures-text">
        <p>Le bilan 2025 neuchâtelois est en baisse (-5% d'infractions). Reste que les atteintes au patrimoine pèsent 69% de la criminalité cantonale (8'584 cas en 2025) : vols et cambriolages demeurent la première préoccupation des ménages.</p>
        <p>Au Locle, ville frontière et de passage, l'enjeu n'est pas le volume : c'est le temps qu'il faut, un soir d'hiver, pour que quelqu'un remarque une présence anormale. Savoir vite ce qui se passe dans son quartier, et pouvoir faire venir une patrouille, y change tout.</p>
      </div>
      <p class="source-note">
        Source : Bilan 2025 de la criminalité, Police neuchâteloise -
        <a href="https://www.ne.ch/autorites/dsdc/pone/statistiques-policieres" target="_blank" rel="noopener">ne.ch</a>.
      </p>
    </div>
  </section>

  <!-- SOLUTION -->
  <section class="section solution-section" id="solution">
    <div class="container">
      <SectionHeader
        eyebrow="Notre solution"
        title="Savoir ce qui se passe au Locle, <em>et pouvoir agir</em>"
        subtitle="Deux fonctions au même endroit : l'information de sécurité fiable de votre secteur, et la possibilité de faire intervenir une patrouille quand vous en avez besoin."
      />
      <BenefitsGrid benefits={solution} cols={3} />
    </div>
  </section>

  <!-- COMMENT CA MARCHE -->
  <section class="section how-section" id="comment-ca-marche">
    <div class="container">
      <SectionHeader
        eyebrow="L'application"
        title="Comment ça marche, <em>concrètement</em>"
        subtitle="En trois étapes depuis votre mobile. Les alertes de votre quartier sont gratuites ; une intervention n'est facturée que si vous la commandez."
      />
      <Steps steps={etapes} />
      <div class="how-ctas">
        <a href="/comment-ca-marche" class="btn-primary">
          Voir le fonctionnement en détail
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="/activer-les-alertes" class="btn-secondary">Activer les alertes - 100% gratuit</a>
      </div>
    </div>
  </section>

  <!-- COUVERTURE -->
  <section class="section coverage-section" id="quartiers">
    <div class="container">
      <SectionHeader
        eyebrow="Couverture"
        title="Présents dans <em>tous les quartiers du Locle</em>"
        subtitle="Du centre aux Monts, en passant par le Communal et la Jaluse, Edgward couvre votre secteur grâce à un réseau de sociétés de sécurité neuchâteloises."
      />
      <ul class="communes" aria-label="Secteurs couverts au Locle">
        {quartiers.map(q => <li>{q}</li>)}
        <li class="communes-more">…et tous les autres secteurs de la ville</li>
      </ul>
    </div>
  </section>

  <!-- CONFIANCE -->
  <section class="section trust-section" id="confiance">
    <div class="container">
      <SectionHeader
        eyebrow="Ils nous font confiance"
        title="Des habitant·es du Locle <em>déjà protégé·es</em>"
      />
      <Testimonials items={temoignages} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section" id="faq">
    <div class="container">
      <SectionHeader
        eyebrow="Questions fréquentes"
        title="La sécurité au Locle, <em>vos questions</em>"
      />
      <div class="faq-wrap">
        <FAQAccordion items={faq} />
      </div>
    </div>
  </section>

  <PartnersGrid
    title="Nos sociétés de sécurité partenaires dans le canton de Neuchâtel"
    partners={partenairesNE}
  />

  <!-- FINAL CTA -->
  <FinalCTA
    title="Reprenez le contrôle de <em>votre sécurité au Locle</em>"
    description="Téléchargez l'application, activez gratuitement les alertes de votre secteur, et gardez la possibilité de faire intervenir une patrouille en cas de besoin."
    appStoreUrl="https://apps.apple.com/ch/app/edgward/id6503622410"
    playStoreUrl="https://play.google.com/store/apps/details?id=ch.edgward.app.clients"
  />
</Base>

<style>
  .hero { background: var(--navy); color: white; padding: 72px 0 56px; overflow: hidden; position: relative; }
  .hero::before { content: ''; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center; position: relative; z-index: 2; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-soft); color: var(--brand-light); padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); margin-bottom: 22px; }
  .canton-flag { border-radius: 3px; box-shadow: 0 0 0 1px rgba(255,255,255,0.3); flex-shrink: 0; display: block; object-fit: cover; }
  .hero h1 { font-size: clamp(36px, 4.5vw, 54px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero-content > p { font-size: 17px; line-height: 1.6; color: #cbd5e1; margin-bottom: 30px; max-width: 520px; }
  .hero-content > p strong { color: white; font-weight: 700; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-note { margin-top: 20px; font-size: 14px; line-height: 1.55; color: #cbd5e1; max-width: 480px; }
  .hero-note svg { color: var(--brand-light); vertical-align: -2px; margin-right: 6px; }
  .hero-note a { color: var(--brand-light); text-decoration: underline; text-underline-offset: 3px; font-weight: 600; }
  .hero-note a:hover { color: white; }

  .hero-visual { display: flex; align-items: center; justify-content: center; min-height: 380px; }
  .newsfeed-demo { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: var(--radius-lg); padding: 20px; width: 100%; max-width: 360px; display: flex; flex-direction: column; gap: 10px; }
  .demo-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
  .demo-title { font-size: 13px; font-weight: 600; color: white; }
  .demo-radius { font-size: 11px; color: var(--brand-light); background: var(--brand-soft); padding: 2px 8px; border-radius: 100px; font-weight: 600; border: 1px solid rgba(70,120,220,0.3); }
  .demo-item { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.04); border-radius: 8px; padding: 10px 12px; border: 1px solid rgba(255,255,255,0.06); }
  .demo-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .demo-dot--red { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.6); }
  .demo-dot--orange { background: #f97316; box-shadow: 0 0 6px rgba(249,115,22,0.6); }
  .demo-dot--yellow { background: #eab308; }
  .demo-dot--blue { background: var(--brand-light); box-shadow: 0 0 6px rgba(70,120,220,0.6); }
  .demo-content { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .demo-content strong { font-size: 12px; color: white; font-weight: 600; }
  .demo-content span { font-size: 10px; color: #94a3b8; }
  .demo-cta { background: var(--brand); color: white; border: none; border-radius: 6px; font-size: 11px; font-weight: 600; padding: 4px 10px; cursor: pointer; font-family: inherit; white-space: nowrap; transition: background 0.2s ease; text-decoration: none; display: inline-block; }
  .demo-cta:hover { background: var(--brand-dark); }

  .intro-section { background: white; padding-bottom: 0; }
  .intro-prose { max-width: 760px; margin: 0 auto; }
  .intro-prose p { font-size: 17px; line-height: 1.7; color: var(--text); }
  .intro-prose strong { color: var(--navy); }

  .figures-section { background: white; }
  .figures-text { max-width: 760px; margin: 0 auto; }
  .figures-text p { font-size: 16px; line-height: 1.7; color: var(--text-muted); margin-bottom: 16px; }
  .figures-text p:last-child { margin-bottom: 0; }
  .figures-text strong { color: var(--navy); }
  .source-note { text-align: center; font-size: 13px; color: var(--text-muted); margin-top: 28px; }
  .source-note a { color: var(--brand); text-decoration: underline; text-underline-offset: 2px; }

  .solution-section { background: var(--soft); }
  .how-section { background: white; }
  .how-ctas { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 40px; }
  .coverage-section { background: var(--soft); }
  .trust-section { background: white; }
  .faq-section { background: var(--soft); }
  .faq-wrap { max-width: 760px; margin: 0 auto; }

  .communes { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
  .communes li { background: white; border: 1px solid var(--border); border-radius: 100px; padding: 7px 16px; font-size: 13px; font-weight: 600; color: var(--navy); }
  .communes-more { background: transparent !important; border: none !important; color: var(--text-muted) !important; font-weight: 400 !important; font-style: italic; }
  .cover-prose { max-width: 680px; margin: 0 auto; text-align: center; font-size: 16px; line-height: 1.7; color: var(--text-muted); }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { order: -1; }
  }
  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
  }
</style>
