---
import Base from '../layouts/Base.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import Steps from '../components/Steps.astro';
import Testimonials from '../components/Testimonials.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionHeader from '../components/SectionHeader.astro';

const benefits = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    title: 'Nouveaux clients sans effort commercial',
    description: "Edgward vous apporte des clients particuliers et PME que vous n'auriez pas atteints avec vos canaux habituels.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    title: 'CA additionnel immédiat',
    description: "Chaque intervention acceptée génère un revenu direct. Pas d'investissement commercial préalable de votre côté.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
    title: 'Flexibilité totale',
    description: "Vous choisissez les missions que vous acceptez selon vos disponibilités. Aucune obligation de résultat.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    title: 'Votre professionnalisme valorisé',
    description: "Les rapports d'intervention et évaluations clients renforcent votre réputation et vos références.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    title: 'Intégration simple',
    description: "Recevez les demandes sur votre téléphone. Pas d'API complexe, pas de refonte de vos process internes.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>',
    title: 'Accompagnement Edgward',
    description: "Formation à l'app, support dédié, et une équipe qui travaille avec vous pour optimiser votre présence sur la plateforme.",
  },
];

const steps = [
  {
    num: '1',
    title: 'Postuler en ligne',
    description: "Remplissez le formulaire ci-dessous. Vos agréments, zone d'intervention et disponibilités nous permettront d'évaluer votre candidature.",
  },
  {
    num: '2',
    title: 'Vérification & contrat',
    description: "Notre équipe vérifie vos certifications et conditions. Sous 5 jours ouvrables, vous recevez votre contrat partenaire.",
  },
  {
    num: '3',
    title: 'Formation app & go-live',
    description: "Une session de 30 minutes pour maîtriser l'app agent. Ensuite, vous êtes en ligne et commencez à recevoir des missions.",
  },
];

const testimonials = [
  {
    quote: "C'est stimulant de recevoir des demandes d'interventions à travers une plateforme innovante, et cela peut permettre d'obtenir plus de demandes tout en ayant de la flexibilité.",
    name: 'Steve Genaine',
    role: 'Python Sécurité SA - Directeur',
    initials: 'SG',
    stars: 5,
  },
];
---

<Base
  title="Rejoindre le réseau Edgward - Pour les entreprises de sécurité"
  description="Devenez partenaire Edgward : accédez à des missions qualifiées sans prospection, facturation simplifiée, tableau de bord dédié. Postulez en ligne."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <span class="hero-eyebrow">Entreprises de sécurité</span>
        <h1>Rejoignez la révolution de la sécurité <em>à la demande</em></h1>
        <p>Devenez partenaire Edgward : accédez à de nouveaux clients, augmentez votre chiffre d'affaires et restez maître de vos disponibilités.</p>
        <div class="hero-ctas">
          <a href="#contact" class="btn-primary">
            Postuler maintenant
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/partenaires" class="btn-secondary">Voir nos partenaires actuels</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="section" id="avantages">
    <div class="container">
      <SectionHeader
        eyebrow="Avantages partenaires"
        title="Ce que vous gagnez en <em>rejoignant Edgward</em>"
        subtitle="Un partenariat pensé pour les entreprises de sécurité qui veulent se concentrer sur leur cœur de métier."
      />
      <BenefitsGrid benefits={benefits} cols={3} />
    </div>
  </section>

  <!-- STEPS -->
  <section class="section steps-section" id="onboarding">
    <div class="container">
      <SectionHeader
        eyebrow="Processus d'intégration"
        title="De la candidature à votre <em>première mission</em>"
        subtitle="Un onboarding structuré et rapide pour vous mettre en service en moins de 2 semaines."
      />
      <Steps steps={steps} />
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="section testimonials-section">
    <div class="container">
      <SectionHeader
        eyebrow="Témoignage"
        title="Ce que disent nos <em>partenaires</em>"
      />
      <Testimonials items={testimonials} />
    </div>
  </section>

  <!-- REQUIREMENTS -->
  <section class="section requirements-section">
    <div class="container">
      <div class="req-block fade-in">
        <SectionHeader
          eyebrow="Prérequis"
          title="Ce que nous demandons <em>à nos partenaires</em>"
          align="left"
        />
        <ul class="req-list">
          <li>Agrément cantonal en cours de validité (sécurité privée)</li>
          <li>Couverture d'assurance responsabilité civile professionnelle</li>
          <li>Capacité à intervenir en moins de 20 minutes dans votre zone</li>
          <li>Disponibilité 24h/24, 7j/7 (ou créneaux définis d'un commun accord)</li>
          <li>Maîtrise du français (allemand ou anglais un plus)</li>
          <li>Engagement à respecter la charte qualité Edgward</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="section contact-section" id="contact">
    <div class="container">
      <SectionHeader
        eyebrow="Candidature"
        title="Postulez pour <em>rejoindre le réseau</em>"
        subtitle="Remplissez le formulaire et notre équipe vous contacte sous 48h ouvrables."
      />
      <ContactForm defaultSubject="Devenir partenaire" />
    </div>
  </section>
</Base>

<style>
  .hero {
    background: var(--navy); color: white;
    padding: 80px 0 72px; text-align: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute;
    top: -200px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
  .hero-eyebrow { display: inline-block; font-size: 12px; color: var(--brand-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; }
  .hero h1 { font-size: clamp(36px, 4.5vw, 54px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero p { font-size: 17px; color: #cbd5e1; line-height: 1.6; max-width: 540px; margin: 0 auto 30px; }
  .hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  .steps-section { background: var(--soft); }
  .testimonials-section { background: white; }

  /* REQUIREMENTS */
  .requirements-section { background: var(--soft); }
  .req-block { max-width: 640px; margin: 0 auto; }
  .req-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .req-list li { font-size: 15px; color: var(--text); padding-left: 28px; position: relative; line-height: 1.5; }
  .req-list li::before { content: ''; position: absolute; left: 0; top: 8px; width: 14px; height: 7px; border-left: 2px solid var(--brand); border-bottom: 2px solid var(--brand); transform: rotate(-45deg); }

  .contact-section { background: white; }
</style>
