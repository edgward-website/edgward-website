---
import Base from '../layouts/Base.astro';
import SoralCallout from '../components/SoralCallout.astro';
import Steps from '../components/Steps.astro';
import BenefitsGrid from '../components/BenefitsGrid.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionHeader from '../components/SectionHeader.astro';

const steps = [
  {
    num: '1',
    title: 'Signer la convention partenariat',
    description: "Un contrat simple entre votre commune et Edgward. Définissez le périmètre de la subvention (montant par habitant, critères d'éligibilité, durée).",
  },
  {
    num: '2',
    title: 'Communiquer à vos habitants',
    description: "Edgward vous fournit le kit de communication : courrier, affiche, FAQ habitant. Vos résidents s'inscrivent directement dans l'app.",
  },
  {
    num: '3',
    title: 'Pilotage budgétaire simple',
    description: "Un tableau de bord dédié vous donne une vue mensuelle des abonnements actifs et de la consommation budgétaire. Aucune gestion opérationnelle de votre côté.",
  },
];

const benefits = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    title: 'Zéro installation matérielle',
    description: "Pas de caméras à installer, pas d'infrastructure à maintenir. L'application existe, les partenaires sécurité aussi.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    title: 'Zéro gestion opérationnelle',
    description: "Chaque habitant gère ses propres interventions. La commune définit le budget, pas l'opérationnel.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>',
    title: 'Complément aux dispositifs existants',
    description: "Edgward s'intègre aux caméras de surveillance et aux systèmes d'alarme déjà en place - c'est une couche supplémentaire, pas un remplacement.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>',
    title: 'Budget prévisible',
    description: "En moyenne CHF 50 subvention pour l'abonnement de base. Vous définissez le plafond. Aucune mauvaise surprise.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
    title: 'Satisfaction citoyenne mesurable',
    description: "Rapport semestriel avec taux d'adoption, nombre d'interventions, notes des agents. Des données concrètes pour votre conseil municipal.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    title: 'Pour toute taille de commune',
    description: "Le modèle fonctionne quelque soit le nombre d’habitants. Offrez une couche supplémentaire de sécurité à vos communiers.",
  },
];

const faqItems = [
  {
    question: "Comment ça s'intègre avec notre police municipale ?",
    answer: "Edgward ne remplace pas la police - il la complète. Les sociétés de sécurité répondent toutes aux conditions régissant la profession (concordat sur les entreprises de sécurité CES) qui interviennent pour les situations qui ne nécessitent pas l'intervention des forces de l'ordre : vérification de domicile, levée de doute, ronde préventive. En cas d'urgence réelle, ils ont l'obligation de contacter le 117.",
  },
  {
    question: "Combien ça coûte vraiment pour la commune ?",
    answer: " La commune peut choisir de subventionner tout ou une partie de l’abonnement à la plateforme. Edgward peut également directement travailler avec un/plusieurs sociétés de sécurité déjà en service pour la commune. Edgward s’adapte toujours aux contraintes budgétaires de la commune ainsi qu’à son objectif en matière de sécurité communale.",
  },
  {
    question: "Faut-il déployer du matériel ou de l'infrastructure ?",
    answer: "Non. Edgward est une application mobile. Aucune installation physique n'est nécessaire ni dans les locaux communaux, ni dans les habitations. Les habitants téléchargent l'app et configurent leur adresse en quelques minutes.",
  },
  {
    question: "Comment communiquer la disponibilité du service aux habitants ?",
    answer: "Edgward fournit un kit de communication clés en main : lettre type à envoyer aux habitants, affiche à mettre en mairie, FAQ à distribuer, et bannière pour votre site web communal. Notre équipe vous accompagne lors du lancement.",
  },
  {
    question: "Que se passe-t-il en cas d'urgence vitale ?",
    answer: "Edgward ne remplace jamais les services d'urgence. En cas d'urgence vitale (incendie, santé, agression), les habitants doivent toujours appeler le 117/118/144 (également directement via l’application). Les agents de sécurité ont une obligation légale de contacter les secours si la situation l'exige.",
  },
];
---

<Base
  title="Communes - Sécurité de proximité pour vos habitants | Edgward"
  description="Le modèle standard : votre commune subventionne une partie de l'abonnement Edgward pour ses habitants. Ils accèdent ainsi facilement à un service de sécurité, à la demande, jour et nuit. Un modèle pratique dans des communes qui ne disposent pas 24/7 de patrouilles institutionnelles ou privées."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-stat-row">
          <div class="hero-stat">
            <strong>5</strong>
            <span>cantons couverts</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <strong>24/24h 7/7j</strong>
            <span>disponibilité</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <strong>100%</strong>
            <span>partenariat flexible</span>
          </div>
        </div>
        <h1>Sécurité de proximité pour vos habitants,<br>sans <em>charge opérationnelle</em></h1>
        <p>Le modèle standard : votre commune subventionne une partie de l'abonnement Edgward pour ses habitants. Ils accèdent ainsi facilement à un service de sécurité, à la demande, jour et nuit. Un modèle pratique dans des communes qui ne disposent pas 24/7 de patrouilles institutionnelles ou privées.</p>
        <div class="hero-ctas">
          <a href="#contact" class="btn-primary">
            Contacter notre équipe
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/comment-ca-marche" class="btn-secondary">
            Voir comment ça marche
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SORAL CALLOUT -->
  <section class="section" id="soral">
    <div class="container">
      <SoralCallout
        badge="★ Première commune partenaire · Soral, GE"
        title="Soral ouvre la voie"
        description="De par sa situation géographique près de la frontière, notre commune connaît un certain nombre de cambriolages. Avec Edgward, les riverains peuvent choisir eux-mêmes les services de sécurité dont ils ont besoin. - Céline Fontaine, adjointe au maire de Soral chargée de la sécurité [source : Tribune de Genève, janvier 2025]"
        ctaLabel="Lire l'article TdG →"
        ctaHref="https://www.tdg.ch/geneve-soral-collabore-avec-une-societe-de-securite-privee-806996337368"
      />

      <!-- STEPS -->
      <SectionHeader
        eyebrow="Mise en place"
        title="3 étapes pour lancer <em>le service</em>"
        subtitle="Du premier contact à l’activation : nous sommes prêt en moins de 30 jours."
        id="comment-ca-marche"
      />
      <Steps steps={steps} />
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="section benefits-section" id="avantages">
    <div class="container">
      <SectionHeader
        eyebrow="Avantages"
        title="Notre équipe vous répond généralement <em>sous 24h</em>"
      />
      <BenefitsGrid benefits={benefits} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section" id="faq">
    <div class="container">
      <SectionHeader
        eyebrow="Questions fréquentes"
        title="Tout ce que vous devez <em>savoir</em>"
      />
      <div class="faq-wrap">
        <FAQAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-section" id="contact">
    <div class="container">
      <SectionHeader
        eyebrow="Contact"
        title="Notre équipe vous répond généralement <em>sous 24h</em>"
        subtitle="Notre responsable partenariats communes répond sous 24h."
      />
      <ContactForm defaultSubject="Commune" />
    </div>
  </section>
</Base>

<style>
  .hero { background: var(--navy); color: white; padding: 80px 0 72px; text-align: center; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: -200px; left: 50%; transform: translateX(-50%); width: 700px; height: 700px; background: radial-gradient(circle, var(--brand-glow) 0%, transparent 60%); pointer-events: none; }
  .hero-inner { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }
  .hero h1 { font-size: clamp(36px, 5vw, 58px); font-weight: 800; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 20px; margin-top: 32px; color: white; }
  .hero h1 em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; color: var(--brand-light); }
  .hero > .container > .hero-inner > p { font-size: 18px; line-height: 1.6; color: #cbd5e1; margin-bottom: 30px; max-width: 560px; margin-left: auto; margin-right: auto; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 0; flex-wrap: wrap; justify-content: center; }
  .hero-stat-row { display: flex; align-items: center; justify-content: center; gap: 32px; flex-wrap: wrap; }
  .hero-stat { text-align: center; }
  .hero-stat strong { display: block; font-size: 32px; font-weight: 800; color: white; letter-spacing: -0.02em; }
  .hero-stat span { font-size: 13px; color: #94a3b8; }
  .hero-stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }
  .benefits-section { background: var(--soft); }
  .faq-section { background: white; }
  .faq-wrap { max-width: 720px; margin: 0 auto; }
  .contact-section { background: var(--soft); }

  @media (max-width: 768px) {
    .hero { padding: 56px 0 48px; }
    .hero-stat-divider { display: none; }
    .hero-stat-row { gap: 24px; }
  }
</style>
